{
  "contract_id": "skills_abi_compat.v1",
  "version": "v1.0",
  "frozen_at": "2026-03-01",
  "owner_lane": "Hub-L1",
  "status": "frozen",
  "scope": [
    "SKC-W1-01",
    "SKC-W1-02"
  ],
  "boundaries": {
    "in_scope": [
      "skill manifest compatibility mapping",
      "import bridge protocol (client pull + upload + pin)",
      "skills data model and audit fields"
    ],
    "out_of_scope": [
      "grant decision logic",
      "runtime security policy threshold tuning"
    ]
  },
  "manifest_mapping": {
    "coverage_target": 1.0,
    "required_core_fields": [
      "skill_id",
      "version",
      "entrypoint.command"
    ],
    "fields": [
      {
        "canonical_field": "schema_version",
        "type": "string",
        "required": false,
        "aliases": [
          "schema_version",
          "manifest_version"
        ],
        "default_value": "xhub.skill_manifest.v1",
        "on_missing": "default_applied"
      },
      {
        "canonical_field": "skill_id",
        "type": "string",
        "required": true,
        "aliases": [
          "skill_id",
          "id"
        ],
        "default_value": null,
        "on_missing": "deny:invalid_manifest"
      },
      {
        "canonical_field": "name",
        "type": "string",
        "required": false,
        "aliases": [
          "name",
          "title"
        ],
        "default_value": "<skill_id>",
        "on_missing": "default_applied"
      },
      {
        "canonical_field": "version",
        "type": "string",
        "required": true,
        "aliases": [
          "version",
          "skill_version"
        ],
        "default_value": null,
        "on_missing": "deny:invalid_manifest"
      },
      {
        "canonical_field": "description",
        "type": "string",
        "required": false,
        "aliases": [
          "description",
          "summary"
        ],
        "default_value": "",
        "on_missing": "default_applied"
      },
      {
        "canonical_field": "entrypoint.runtime",
        "type": "string",
        "required": false,
        "aliases": [
          "entrypoint.runtime",
          "runtime",
          "entrypoint.type"
        ],
        "default_value": "node",
        "on_missing": "default_applied"
      },
      {
        "canonical_field": "entrypoint.command",
        "type": "string",
        "required": true,
        "aliases": [
          "entrypoint.command",
          "entrypoint.exec",
          "command",
          "main",
          "runner.command",
          "entrypoint"
        ],
        "default_value": null,
        "on_missing": "deny:invalid_manifest"
      },
      {
        "canonical_field": "entrypoint.args",
        "type": "array<string>",
        "required": false,
        "aliases": [
          "entrypoint.args",
          "entrypoint.arguments",
          "args"
        ],
        "default_value": [],
        "on_missing": "default_applied"
      },
      {
        "canonical_field": "capabilities_required",
        "type": "array<string>",
        "required": false,
        "aliases": [
          "capabilities_required",
          "capabilities",
          "required_capabilities"
        ],
        "default_value": [],
        "on_missing": "default_applied"
      },
      {
        "canonical_field": "network_policy.direct_network_forbidden",
        "type": "boolean",
        "required": false,
        "aliases": [
          "network_policy.direct_network_forbidden"
        ],
        "default_value": true,
        "on_missing": "default_applied"
      },
      {
        "canonical_field": "publisher.publisher_id",
        "type": "string",
        "required": false,
        "aliases": [
          "publisher.publisher_id",
          "publisher_id",
          "publisher.id",
          "author_id",
          "author"
        ],
        "default_value": "unknown",
        "on_missing": "default_applied"
      },
      {
        "canonical_field": "install_hint",
        "type": "string",
        "required": false,
        "aliases": [
          "install_hint",
          "install.command",
          "install_hint.command"
        ],
        "default_value": "",
        "on_missing": "default_applied"
      }
    ],
    "derived_fields": [
      {
        "name": "package_sha256",
        "source": "sha256(package_bytes)",
        "purpose": "content-addressed dedup key"
      },
      {
        "name": "manifest_sha256",
        "source": "sha256(canonical_manifest_json)",
        "purpose": "normalized manifest integrity + audit trace"
      },
      {
        "name": "mapping_aliases_used",
        "source": "mapper",
        "purpose": "alias usage audit"
      },
      {
        "name": "defaults_applied",
        "source": "mapper",
        "purpose": "default coverage audit"
      }
    ]
  },
  "deny_codes": [
    {
      "deny_code": "invalid_manifest",
      "stage": "upload.validate_manifest",
      "retryable": true,
      "fix_suggestion": "补齐 skill_id/version/entrypoint.command，并确保字段类型正确。"
    },
    {
      "deny_code": "invalid_manifest_json",
      "stage": "upload.parse_manifest",
      "retryable": true,
      "fix_suggestion": "修复 skill.json 为合法 JSON（先执行 jq .）。"
    },
    {
      "deny_code": "missing_manifest_json",
      "stage": "upload.parse_manifest",
      "retryable": true,
      "fix_suggestion": "传入 manifest_json，或确保包内包含 skill.json。"
    },
    {
      "deny_code": "invalid_package_bytes",
      "stage": "upload.validate_package",
      "retryable": true,
      "fix_suggestion": "重新打包并确认上传的是 .tgz/.zip 二进制内容。"
    },
    {
      "deny_code": "source_not_allowlisted",
      "stage": "upload.source_gate",
      "retryable": true,
      "fix_suggestion": "改用 allowlist 来源，或先登记 source_id 到 skill_sources.json。"
    },
    {
      "deny_code": "skills_store_unavailable",
      "stage": "upload.store_access",
      "retryable": true,
      "fix_suggestion": "检查 HUB_RUNTIME_BASE_DIR 可写性与 skills_store 目录。"
    },
    {
      "deny_code": "package_too_large",
      "stage": "upload.validate_package",
      "retryable": true,
      "fix_suggestion": "减小包体积，或调整 HUB_SKILLS_MAX_PACKAGE_MB。"
    },
    {
      "deny_code": "invalid_pin_request",
      "stage": "pin.validate_request",
      "retryable": true,
      "fix_suggestion": "补齐 skill_id + package_sha256。"
    },
    {
      "deny_code": "unsupported_scope",
      "stage": "pin.validate_scope",
      "retryable": false,
      "fix_suggestion": "scope 仅支持 global/project。"
    },
    {
      "deny_code": "missing_user_id",
      "stage": "pin.identity",
      "retryable": true,
      "fix_suggestion": "在 client identity 中补齐 user_id。"
    },
    {
      "deny_code": "missing_project_id",
      "stage": "pin.identity",
      "retryable": true,
      "fix_suggestion": "project scope pin 时补齐 project_id。"
    },
    {
      "deny_code": "package_not_found",
      "stage": "pin.lookup",
      "retryable": true,
      "fix_suggestion": "先执行 upload/import，再执行 pin。"
    },
    {
      "deny_code": "skill_package_mismatch",
      "stage": "pin.lookup",
      "retryable": true,
      "fix_suggestion": "使用上传响应返回的 skill_id 与 package_sha256。"
    }
  ],
  "compatibility_matrix": [
    {
      "case_id": "OCM-001",
      "status": "supported",
      "description": "Canonical xhub.skill_manifest.v1 fields",
      "expected": "upload + pin pass"
    },
    {
      "case_id": "OCM-002",
      "status": "partial",
      "description": "Legacy aliases (id, skill_version, main, capabilities, publisher_id)",
      "expected": "mapped with mapping_aliases_used audit"
    },
    {
      "case_id": "OCM-003",
      "status": "blocked",
      "description": "Missing entrypoint.command",
      "expected": "deny: invalid_manifest"
    },
    {
      "case_id": "OCM-004",
      "status": "blocked",
      "description": "source_id outside allowlist",
      "expected": "deny: source_not_allowlisted"
    },
    {
      "case_id": "OCM-005",
      "status": "supported",
      "description": "Repeated upload with identical package bytes",
      "expected": "dedup by package_sha256 + already_present=true"
    },
    {
      "case_id": "OCM-006",
      "status": "supported",
      "description": "Repeated pin of same scope/user/project/skill",
      "expected": "upsert idempotent + previous_package_sha256 stable"
    },
    {
      "case_id": "OCM-007",
      "status": "blocked",
      "description": "memory_core scope pin via client API",
      "expected": "deny: unsupported_scope"
    }
  ],
  "import_bridge_contract": {
    "bridge_id": "skill_client_pull_upload_pin.v1",
    "flow": [
      {
        "step": 1,
        "name": "client_pull",
        "owner": "client/skill",
        "api": "local package pull (npx skills add compatible)",
        "output": [
          "package_bytes",
          "manifest_json"
        ]
      },
      {
        "step": 2,
        "name": "upload",
        "owner": "Hub",
        "api": "HubSkills.UploadSkillPackage",
        "output": [
          "package_sha256",
          "manifest_sha256",
          "mapping_aliases_used",
          "defaults_applied"
        ]
      },
      {
        "step": 3,
        "name": "pin",
        "owner": "Hub",
        "api": "HubSkills.SetSkillPin",
        "output": [
          "scope",
          "user_id",
          "project_id",
          "skill_id",
          "package_sha256",
          "previous_package_sha256"
        ]
      }
    ],
    "idempotency": {
      "upload_dedup_key": "package_sha256",
      "pin_upsert_key": "scope + user_id + project_id + skill_id",
      "request_id": {
        "required": false,
        "note": "可选追踪字段，不作为 v1 幂等主键"
      }
    },
    "kpi_targets": {
      "skill_import_success_rate_gte": 0.98,
      "import_to_first_run_p95_ms_lte": 12000
    }
  },
  "audit_fields": {
    "event_types": [
      "skills.package.imported",
      "skills.pin.updated",
      "skills.revoked"
    ],
    "common": [
      "request_id",
      "device_id",
      "user_id",
      "app_id",
      "project_id",
      "session_id",
      "ok",
      "error_code",
      "error_message"
    ],
    "skills.package.imported.success_ext_json": [
      "source_id",
      "package_sha256",
      "manifest_sha256",
      "abi_compat_version",
      "compatibility_state",
      "mapping_aliases_used[]",
      "defaults_applied[]",
      "skill_id",
      "version",
      "entrypoint_runtime",
      "entrypoint_command",
      "entrypoint_args[]",
      "package_size_bytes",
      "already_present"
    ],
    "skills.package.imported.failure_ext_json": [
      "source_id",
      "deny_code",
      "fix_suggestion"
    ],
    "skills.pin.updated.success_ext_json": [
      "scope",
      "skill_id",
      "previous_package_sha256",
      "package_sha256"
    ],
    "skills.pin.updated.failure_ext_json": [
      "scope",
      "skill_id",
      "package_sha256",
      "deny_code",
      "fix_suggestion"
    ]
  }
}
