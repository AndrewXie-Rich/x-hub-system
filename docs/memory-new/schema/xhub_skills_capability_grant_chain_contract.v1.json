  "skill_preflight_binding_standard": {
    "preflight_order": [
      "resolve_capabilities_required",
      "derive_required_grant_scope_floor",
      "risk_floor_guard",
      "validate_exec_binding_inputs",
      "persist_approval_binding",
      "evaluate_policy",
      "grant_decision"
    ],
    "unknown_capability_policy": {
      "mode": "fail_closed",
      "deny_code": "policy_denied"
    },
    "approval_binding_checks": [
      {
        "check_id": "binding.argv.type",
        "description": "exec_argv accepts string arguments only",
        "deny_code": "approval_binding_invalid"
      },
      {
        "check_id": "binding.cwd.absolute_realpath",
        "description": "exec_cwd must be absolute canonical realpath",
        "deny_code": "approval_cwd_invalid"
      },
      {
        "check_id": "binding.argv.exact_match",
        "description": "execute argv must exactly match approval binding",
        "deny_code": "approval_argv_mismatch"
      },
      {
        "check_id": "binding.cwd.exact_match",
        "description": "execute cwd canonical path must exactly match approval binding",
        "deny_code": "approval_cwd_mismatch"
      },
      {
        "check_id": "binding.identity.hash",
        "description": "identity hash must bind session canonical project scope",
        "deny_code": "approval_identity_mismatch"
      }
    ],
    "grant_checks": [
      {
        "check_id": "grant.required_for_high_risk",
