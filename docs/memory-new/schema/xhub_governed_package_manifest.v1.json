{
  "schema_version": "xhub.governed_package_manifest.v1",
  "contract_version": "2026-03-27",
  "contract_id": "HUB-L3-GPK-W1-01",
  "owner_lane": "Hub Runtime / Packaging / Security / QA",
  "execution_chain": [
    "ingress",
    "risk_classify",
    "policy",
    "grant",
    "execute",
    "audit"
  ],
  "fixed_decisions": [
    "package_is_not_trust_root",
    "activation_is_not_grant",
    "auth_success_is_not_permission",
    "xt_and_gateway_surfaces_are_not_durable_truth_sources",
    "dynamic_package_growth_requires_stage_validate_review_sign_promote_activate",
    "official_package_integrity_must_fail_closed_on_checksum_or_signature_mismatch",
    "manifest_primary_source_may_not_use_source_fallback_as_source_type",
    "fallback_path_must_bind_to_the_same_manifest_identity_and_integrity_chain"
  ],
  "package_kind_enum": [
    "official_skill",
    "operator_channel",
    "connector",
    "local_provider_pack",
    "external_adapter"
  ],
  "trust_tier_enum": [
    "hub_native",
    "governed_package",
    "local_runner_bound",
    "external_process_low_trust"
  ],
  "owner_scope_enum": [
    "user",
    "project",
    "workspace",
    "organization",
    "system"
  ],
  "source_type_enum": [
    "embedded_catalog",
    "signed_remote_catalog",
    "local_staging",
    "source_fallback"
  ],
  "checksum_algorithm_enum": [
    "sha256"
  ],
  "artifact_kind_enum": [
    "bundle",
    "wasm_module",
    "service_connector",
    "python_pack",
    "binary_helper",
    "manifest_only"
  ],
  "auth_method_enum": [
    "oauth",
    "manual_secret",
    "approve_once_binding",
    "shared_auth_group",
    "none"
  ],
  "grant_scope_enum": [
    "readonly",
    "privileged",
    "critical"
  ],
  "capability_kind_enum": [
    "http",
    "workspace_read",
    "package_invoke",
    "secret_mapping",
    "webhook",
    "channel_surface",
    "device_execution_bridge"
  ],
  "setup_mode_enum": [
    "full_onboarding",
    "provider_only_repair",
    "channel_only_repair",
    "package_only_repair",
    "quick_setup"
  ],
  "doctor_bundle_enum": [
    "official_skills",
    "operator_channels",
    "local_provider_runtime",
    "trusted_automation_readiness"
  ],
  "compatibility_kind_enum": [
    "contract",
    "protocol",
    "runtime"
  ],
  "doctor_check_kind_enum": [
    "manifest_parse",
    "artifact_integrity",
    "auth_readiness",
    "endpoint_readiness",
    "grant_readiness",
    "runtime_readiness",
    "recent_failure_summary",
    "paired_surface_readiness",
    "permission_owner_readiness"
  ],
  "package_state_enum": [
    "discovered",
    "staged",
    "verified",
    "auth_required",
    "approval_required",
    "ready",
    "active",
    "degraded",
    "revoked",
    "removed"
  ],
  "lifecycle_transition_expectations": [
    {
      "from": "discovered",
      "to": "staged",
      "required_checks": [
        "catalog_resolved",
        "artifact_selected"
      ]
    },
    {
      "from": "staged",
      "to": "verified",
      "required_checks": [
        "manifest_parse",
        "artifact_integrity",
        "signature_verification_if_official"
      ]
    },
    {
      "from": "verified",
      "to": "auth_required",
      "required_checks": [
        "auth_contract_present"
      ]
    },
    {
      "from": "auth_required",
      "to": "approval_required",
      "required_checks": [
        "auth_validation_succeeded"
      ]
    },
    {
      "from": "approval_required",
      "to": "ready",
      "required_checks": [
        "grant_readiness_satisfied",
        "paired_surface_rules_satisfied",
        "permission_owner_rules_satisfied"
      ]
    },
    {
      "from": "ready",
      "to": "active",
      "required_checks": [
        "runtime_compatibility_passed",
        "activation_audit_written"
      ]
    },
    {
      "from": "active",
      "to": "degraded",
      "required_checks": [
        "doctor_or_runtime_failure_detected"
      ]
    },
    {
      "from": "any",
      "to": "revoked",
      "required_checks": [
        "revoke_or_kill_signal_received",
        "audit_written"
      ]
    }
  ],
  "objects": {
    "xhub.governed_package_manifest.v1": {
      "required_fields": [
        "schema_version",
        "package_id",
        "display_name",
        "kind",
        "version",
        "contract_version",
        "protocol_compat_version",
        "description",
        "keywords",
        "tags",
        "owner_scope",
        "trust_tier",
        "source",
        "artifacts",
        "auth_summary",
        "capabilities",
        "required_grants",
        "doctor_checks",
        "audit_contract",
        "quality_evidence",
        "lifecycle_policy"
      ],
      "nested_required_fields": {
        "source": [
          "type",
          "catalog_id",
          "manifest_ref",
          "provenance",
          "update_channel"
        ],
        "auth_summary": [
          "method",
          "provider",
          "secrets",
          "shared_auth",
          "setup_url",
          "token_hint",
          "validation_endpoint",
          "grant_scope_required",
          "paired_surface_required",
          "owner_local_approval_required",
          "remote_export_posture_required"
        ],
        "audit_contract": [
          "event_namespace",
          "required_fields",
          "deny_codes",
          "evidence_export_required"
        ],
        "quality_evidence": [
          "required_replay_scenarios",
          "required_fuzz_targets",
          "compatibility_gates",
          "smoke_routes",
          "degraded_recovery_paths"
        ],
        "lifecycle_policy": [
          "initial_state",
          "eligible_states",
          "promotion_path",
          "revoke_behavior",
          "kill_switch_behavior",
          "approval_required_states"
        ]
      },
      "enum_refs": {
        "kind": "package_kind_enum",
        "trust_tier": "trust_tier_enum",
        "owner_scope": "owner_scope_enum"
      },
      "rules": [
        "Every capability that may cause irreversible device, connector, or network side effects must resolve through policy, grant, and audit stages.",
        "Manifest validity does not authorize execution; runtime still evaluates policy and grant at request time.",
        "Packages may not self-declare hub_native unless explicitly shipped as control-plane primitive.",
        "Manifest source.type is the primary distribution source and may not be set to source_fallback.",
        "Manifest declarations may narrow but never expand trust tier, capability scope, or required grants when fallback paths are used."
      ]
    },
    "xhub.package_source.v1": {
      "required_fields": [
        "type",
        "catalog_id",
        "manifest_ref",
        "provenance",
        "update_channel"
      ],
      "optional_fields": [
        "integrity_chain_id",
        "allow_source_fallback",
        "fallback_audit_event_code"
      ],
      "enum_refs": {
        "type": "source_type_enum"
      },
      "rules": [
        "Embedded catalog is the default offline source for official packages.",
        "Primary source metadata may not encode source_fallback as type; fallback semantics belong to registry fallback_source metadata.",
        "Source fallback is allowed only when fallback artifacts or source bundles pass the same integrity chain.",
        "Fallback path metadata must not widen declared trust tier, capabilities, or required grant scope."
      ]
    },
    "xhub.package_artifact.v1": {
      "required_fields": [
        "artifact_id",
        "artifact_kind",
        "download_url",
        "sha256",
        "signature_ref",
        "size_bytes",
        "fallback_allowed",
        "capabilities_manifest_ref",
        "doctor_bundle_ref"
      ],
      "optional_fields": [
        "checksum_algorithm",
        "integrity_chain_id",
        "fallback_of_artifact_id"
      ],
      "enum_refs": {
        "artifact_kind": "artifact_kind_enum",
        "checksum_algorithm": "checksum_algorithm_enum"
      },
      "rules": [
        "Official packages require signature verification in addition to checksum verification.",
        "Source fallback does not bypass checksum or signature verification.",
        "The sha256 field is expected to be a full package digest and must be validated before activation.",
        "When fallback_allowed is true, fallback artifacts still require the same checksum and signature verification semantics as primary artifacts."
      ]
    },
    "xhub.package_auth_summary.v1": {
      "required_fields": [
        "method",
        "provider",
        "secrets",
        "shared_auth",
        "setup_url",
        "token_hint",
        "validation_endpoint",
        "grant_scope_required",
        "paired_surface_required",
        "owner_local_approval_required",
        "remote_export_posture_required"
      ],
      "enum_refs": {
        "method": "auth_method_enum",
        "grant_scope_required": "grant_scope_enum"
      },
      "rules": [
        "Auth success means credentials are ready, not that high-risk actions may run.",
        "Packages that touch device execution bridges must declare paired surface, permission owner, and remote export posture requirements."
      ]
    },
    "xhub.package_capability.v1": {
      "required_fields": [
        "capability_id",
        "kind",
        "description",
        "required_grant_scope",
        "risk_tier",
        "audit_event_type"
      ],
      "nested_required_fields": {
        "http_config": [
          "allowlist",
          "methods",
          "path_prefix",
          "max_request_bytes",
          "max_response_bytes",
          "timeout_ms",
          "rate_limit",
          "credential_mappings"
        ],
        "device_bridge_requirements": [
          "requires_paired_device_profile",
          "requires_project_binding",
          "requires_permission_owner",
          "requires_hub_remote_posture"
        ],
        "secret_mapping": [
          "secret_name",
          "injection_location",
          "host_patterns",
          "scope",
          "rotation_policy"
        ]
      },
      "enum_refs": {
        "kind": "capability_kind_enum",
        "required_grant_scope": "grant_scope_enum"
      },
      "rules": [
        "HTTP capability must be allowlist-based and explicit about method, path prefix, and credential mapping.",
        "Device execution bridge capability must remain gated by trusted automation readiness and cannot self-authorize side effects."
      ]
    },
    "xhub.package_doctor_check.v1": {
      "required_fields": [
        "check_id",
        "bundle",
        "check_kind",
        "blocking",
        "expectation",
        "degraded_state_on_fail"
      ],
      "enum_refs": {
        "bundle": "doctor_bundle_enum",
        "check_kind": "doctor_check_kind_enum",
        "degraded_state_on_fail": "package_state_enum"
      },
      "rules": [
        "Blocking checks must fail closed for integrity, auth, grant, or runtime readiness issues.",
        "Doctor checks are diagnostics and do not replace policy or grant evaluation."
      ]
    },
    "xhub.package_quality_evidence.v1": {
      "required_fields": [
        "required_replay_scenarios",
        "required_fuzz_targets",
        "compatibility_gates",
        "smoke_routes",
        "degraded_recovery_paths"
      ],
      "array_enum_refs": {
        "compatibility_gates": "compatibility_kind_enum"
      },
      "rules": [
        "Every governed package must specify at least one replay scenario and one degraded recovery path.",
        "High-risk parsers or validators must name fuzz targets explicitly."
      ]
    },
    "xhub.package_lifecycle_policy.v1": {
      "required_fields": [
        "initial_state",
        "eligible_states",
        "promotion_path",
        "revoke_behavior",
        "kill_switch_behavior",
        "approval_required_states"
      ],
      "enum_refs": {
        "initial_state": "package_state_enum"
      },
      "array_enum_refs": {
        "eligible_states": "package_state_enum",
        "approval_required_states": "package_state_enum"
      },
      "rules": [
        "Packages do not enter active directly from staged or verified states.",
        "Revoked packages may not auto-return to ready or active without a new promotion flow."
      ]
    },
    "xhub.package_audit_contract.v1": {
      "required_fields": [
        "event_namespace",
        "required_fields",
        "deny_codes",
        "evidence_export_required"
      ],
      "rules": [
        "Package audit contracts must preserve chain stage visibility across ingress, policy, grant, execute, and audit.",
        "Activation, revoke, and degraded transitions require auditable event records."
      ]
    }
  }
}
