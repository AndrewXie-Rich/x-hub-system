{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AX Hub AuditEvent v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "event_id", "event_type", "created_at_ms", "actor", "outcome"],
  "properties": {
    "schema_version": { "type": "string", "const": "audit.v1" },
    "event_id": { "type": "string", "minLength": 1 },
    "event_type": { "type": "string", "minLength": 1 },
    "created_at_ms": { "type": "integer", "description": "Unix timestamp in milliseconds." },
    "severity": { "type": "string", "enum": ["info", "warn", "error", "security"] },

    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["device_id", "app_id"],
      "properties": {
        "device_id": { "type": "string", "minLength": 1 },
        "user_id": { "type": "string" },
        "app_id": { "type": "string", "minLength": 1 },
        "project_id": { "type": "string" },
        "session_id": { "type": "string" },
        "ip": { "type": "string", "description": "Best-effort client IP." },
        "client_version": { "type": "string" }
      }
    },

    "context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "org_id": { "type": "string" },
        "tenant_id": { "type": "string" },
        "trace_id": { "type": "string" },
        "span_id": { "type": "string" }
      }
    },

    "request": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "request_id": { "type": "string" },
        "correlation_id": { "type": "string" },
        "capability": {
          "type": "string",
          "enum": ["ai.generate.local", "ai.generate.paid", "web.fetch", "remote_model_call", "unknown"]
        },
        "model_id": { "type": "string" },
        "tool": { "type": "string", "description": "Optional tool name, e.g. need_network/web_fetch." },
        "url": { "type": "string" },
        "method": { "type": "string" },
        "timeout_sec": { "type": "integer" },
        "max_bytes": { "type": "integer" }
      }
    },

    "decision": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["allow", "deny", "queued", "approved", "auto_approved", "revoked"]
        },
        "policy_id": { "type": "string" },
        "grant_request_id": { "type": "string" },
        "grant_id": { "type": "string" },
        "approver_id": { "type": "string" },
        "note": { "type": "string" }
      }
    },

    "usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prompt_tokens": { "type": "integer", "minimum": 0 },
        "completion_tokens": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 },
        "cost_usd_estimate": { "type": "number", "minimum": 0 }
      }
    },

    "network": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowed": { "type": "boolean" },
        "target_url": { "type": "string" },
        "target_host": { "type": "string" },
        "status": { "type": "integer" },
        "bytes_in": { "type": "integer", "minimum": 0 },
        "bytes_out": { "type": "integer", "minimum": 0 }
      }
    },

    "content": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prompt_hash": { "type": "string" },
        "output_hash": { "type": "string" },
        "summary": { "type": "string", "description": "Redacted, policy-safe summary." }
      }
    },

    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok"],
      "properties": {
        "ok": { "type": "boolean" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "error_code": { "type": "string" },
        "error_message": { "type": "string" },
        "retryable": { "type": "boolean" }
      }
    },

    "ext": {
      "type": "object",
      "additionalProperties": true,
      "description": "Extension bag for forward-compat fields."
    }
  }
}
