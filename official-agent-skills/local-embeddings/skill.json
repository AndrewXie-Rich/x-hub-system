{
  "schema_version": "xhub.skill_manifest.v1",
  "skill_id": "local-embeddings",
  "name": "Local Embeddings",
  "version": "1.0.0",
  "description": "Governed local embedding wrapper over Hub local model execution for vector search, retrieval, and semantic indexing tasks.",
  "entrypoint": {
    "runtime": "text",
    "command": "cat",
    "args": [
      "SKILL.md"
    ]
  },
  "capabilities_required": [
    "ai.embed.local"
  ],
  "input_schema_ref": "schema://local-embeddings.input",
  "output_schema_ref": "schema://local-embeddings.output",
  "side_effect_class": "read_only",
  "risk_level": "low",
  "requires_grant": false,
  "timeout_ms": 15000,
  "max_retries": 0,
  "governed_dispatch": {
    "tool": "run_local_task",
    "fixed_args": {
      "task_kind": "embedding"
    },
    "passthrough_args": [
      "model_id",
      "preferred_model_id",
      "text",
      "texts",
      "query",
      "documents",
      "input",
      "options",
      "device_id",
      "timeout_sec"
    ],
    "arg_aliases": {
      "model_id": [
        "model"
      ],
      "text": [
        "content",
        "value"
      ],
      "texts": [
        "inputs",
        "rows"
      ]
    },
    "required_any": [
      [
        "text",
        "texts",
        "query",
        "documents"
      ]
    ],
    "exactly_one_of": []
  },
  "governed_dispatch_notes": [
    "Routes through XT run_local_task with task_kind=embedding.",
    "If model_id/preferred_model_id is omitted, XT binds the best runnable Hub local embedding model for this task kind."
  ],
  "network_policy": {
    "direct_network_forbidden": true
  },
  "publisher": {
    "publisher_id": "xhub.official"
  },
  "install_hint": "Publish and sign this wrapper into the official dist before recommending Hub pinning; until then treat it as source-present only."
}
