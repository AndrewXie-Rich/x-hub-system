{
  "schema_version": "xhub.skill_manifest.v1",
  "skill_id": "local-vision",
  "name": "Local Vision",
  "version": "1.0.0",
  "description": "Governed local image-understanding wrapper over Hub local model execution for screenshots, documents, and image inspection.",
  "entrypoint": {
    "runtime": "text",
    "command": "cat",
    "args": [
      "SKILL.md"
    ]
  },
  "capabilities_required": [
    "ai.vision.local"
  ],
  "input_schema_ref": "schema://local-vision.input",
  "output_schema_ref": "schema://local-vision.output",
  "side_effect_class": "read_only",
  "risk_level": "medium",
  "requires_grant": false,
  "timeout_ms": 45000,
  "max_retries": 0,
  "governed_dispatch": {
    "tool": "run_local_task",
    "fixed_args": {
      "task_kind": "vision_understand"
    },
    "passthrough_args": [
      "model_id",
      "preferred_model_id",
      "image_path",
      "image_paths",
      "image",
      "multimodal_messages",
      "text",
      "prompt",
      "input",
      "options",
      "device_id",
      "timeout_sec"
    ],
    "arg_aliases": {
      "model_id": [
        "model"
      ],
      "image_path": [
        "path",
        "file"
      ],
      "image_paths": [
        "files"
      ],
      "text": [
        "content",
        "value"
      ]
    },
    "required_any": [
      [
        "image_path",
        "image_paths",
        "image",
        "multimodal_messages"
      ]
    ],
    "exactly_one_of": []
  },
  "governed_dispatch_notes": [
    "Routes through XT run_local_task with task_kind=vision_understand.",
    "If model_id/preferred_model_id is omitted, XT binds the best runnable Hub local vision model for this task kind.",
    "Keep OCR-specific extraction on the dedicated local-ocr wrapper instead of overloading this skill."
  ],
  "network_policy": {
    "direct_network_forbidden": true
  },
  "publisher": {
    "publisher_id": "xhub.official"
  },
  "install_hint": "Publish and sign this wrapper into the official dist before recommending Hub pinning; until then treat it as source-present only."
}
