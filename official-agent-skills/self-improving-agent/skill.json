{
  "schema_version": "xhub.skill_manifest.v1",
  "skill_id": "self-improving-agent",
  "name": "Self Improving Agent",
  "version": "1.0.0",
  "description": "Supervisor retrospective and self-improvement workflow pack for learning from failed runs without bypassing governance.",
  "input_schema_ref": "schema://self-improving-agent.input",
  "output_schema_ref": "schema://self-improving-agent.output",
  "side_effect_class": "read_only",
  "risk_level": "medium",
  "requires_grant": false,
  "timeout_ms": 15000,
  "max_retries": 1,
  "entrypoint": {
    "runtime": "text",
    "command": "cat",
    "args": [
      "SKILL.md"
    ]
  },
  "governed_dispatch": {
    "tool": "memory_snapshot",
    "fixed_args": {
      "mode": "supervisor_orchestration",
      "retrospective": true
    },
    "passthrough_args": [
      "focus",
      "limit",
      "include_doctor",
      "include_incidents",
      "include_skill_calls",
      "include_plan",
      "include_memory"
    ]
  },
  "capabilities_required": [
    "memory.snapshot",
    "project.snapshot",
    "repo.read.file"
  ],
  "network_policy": {
    "direct_network_forbidden": true
  },
  "publisher": {
    "publisher_id": "xhub.official"
  },
  "install_hint": "Install for Supervisor retrospectives and governed workflow tuning.",
  "quality_evidence_status": {
    "replay": "missing",
    "fuzz": "missing",
    "doctor": "passed",
    "smoke": "passed"
  }
}
