resolve_node_bin() {
  kit_dir="$(trim "${1:-}")"
  override="$(trim "${AXHUBCTL_NODE_BIN:-}")"
  if [ -n "$override" ]; then
    [ -x "$override" ] || die "AXHUBCTL_NODE_BIN is not executable: $override"
    echo "$override"
    return 0
  fi
  prefer_bundled="$(trim "${AXHUBCTL_PREFER_BUNDLED_NODE:-}")"
  if [ "$prefer_bundled" = "1" ] || [ "$prefer_bundled" = "true" ] || [ "$prefer_bundled" = "yes" ]; then
    if [ -n "$kit_dir" ] && [ -x "$kit_dir/bin/relflowhub_node" ]; then
      echo "$kit_dir/bin/relflowhub_node"
      return 0
    fi
  fi
  self_dir="$(CDPATH= cd -- "$(dirname "$0")" 2>/dev/null && pwd -P || true)"
  if [ -n "$self_dir" ] && [ -x "$self_dir/relflowhub_node" ]; then
    echo "$self_dir/relflowhub_node"
    return 0
  fi
  if command -v node >/dev/null 2>&1; then
    command -v node
    return 0
  fi
  if [ -n "$kit_dir" ] && [ -x "$kit_dir/bin/relflowhub_node" ]; then
    echo "$kit_dir/bin/relflowhub_node"
    return 0
  fi
  return 1
}

client_kit_info() {
  hub="$(trim "${1:-}")"
  pairing_port="$(trim "${2:-}")"
  [ -n "$hub" ] || return 1
  [ -n "$pairing_port" ] || pairing_port="50052"

  # Preferred: JSON manifest (stable fields, URL can reflect reverse proxies).
  json_url="http://${hub}:${pairing_port}/install/axhub_client_kit.json"
  json="$(curl -fsS "$json_url" 2>/dev/null || true)"
  if [ -n "$json" ]; then
    kit_url="$(json_get_string url "$json")"
    kit_sha="$(json_get_string sha256 "$json")"
    if [ -n "$(trim "$kit_url")" ] && [ -n "$(trim "$kit_sha")" ]; then
      echo "$(trim "$kit_url")|$(trim "$kit_sha")"
      return 0
    fi
  fi

  # Fallback: well-known paths.
  kit_url="http://${hub}:${pairing_port}/install/axhub_client_kit.tgz"
  sha_txt="$(curl -fsS "http://${hub}:${pairing_port}/install/axhub_client_kit.tgz.sha256" 2>/dev/null || true)"
  kit_sha="$(echo "$sha_txt" | awk '{print $1}' | head -n 1)"
  if [ -n "$(trim "$kit_sha")" ]; then
    echo "$kit_url|$(trim "$kit_sha")"
    return 0
  fi
  return 1
}

