    p_hub_instance_id="$(trim "${AXHUB_DISCOVERY_LAST_HUB_INSTANCE_ID:-}")"
  fi
  if [ -z "$p_lan_discovery_name" ] && [ -n "$(trim "${AXHUB_DISCOVERY_LAST_LAN_DISCOVERY_NAME:-}")" ]; then
    p_lan_discovery_name="$(trim "${AXHUB_DISCOVERY_LAST_LAN_DISCOVERY_NAME:-}")"
  fi
  if [ -z "$p_pairing_profile_epoch" ] && [ -n "$(trim "${AXHUB_DISCOVERY_LAST_PAIRING_PROFILE_EPOCH:-}")" ]; then
    p_pairing_profile_epoch="$(trim "${AXHUB_DISCOVERY_LAST_PAIRING_PROFILE_EPOCH:-}")"
  fi
  if [ -z "$p_route_pack_version" ] && [ -n "$(trim "${AXHUB_DISCOVERY_LAST_ROUTE_PACK_VERSION:-}")" ]; then
    p_route_pack_version="$(trim "${AXHUB_DISCOVERY_LAST_ROUTE_PACK_VERSION:-}")"
  fi

  p_app_id="ax_terminal"
  p_device_name=""
  p_rid=""
  p_secret=""
  if [ -f "$PAIRING_ENV" ]; then
    # shellcheck disable=SC1090
    . "$PAIRING_ENV"
    p_app_id="${AXHUB_APP_ID:-$p_app_id}"
    p_device_name="${AXHUB_DEVICE_NAME:-$p_device_name}"
    p_rid="${AXHUB_PAIRING_REQUEST_ID:-$p_rid}"
    p_secret="${AXHUB_PAIRING_SECRET:-$p_secret}"
  fi
  write_pairing_env_state "$p_host" "$p_pairing_port" "$p_grpc_port" "$p_app_id" "$p_device_name" "$p_rid" "$p_secret" "$p_internet_host" "$p_hub_instance_id" "$p_lan_discovery_name" "$p_pairing_profile_epoch" "$p_route_pack_version"
}

probe_pairing_health() {
  h_host="$(trim "${1:-}")"
  h_pairing_port="$(uint_or_default "${2:-50052}" "50052")"
  h_timeout_sec="$(uint_or_default "${3:-2}" "2")"
  [ -n "$h_host" ] || return 1
  h_resp="$(curl -fsS --connect-timeout "$h_timeout_sec" --max-time "$h_timeout_sec" "http://${h_host}:${h_pairing_port}/health" 2>/dev/null || true)"
  [ -n "$h_resp" ] || return 1
  h_ok="$(json_get_bool ok "$h_resp")"
  h_service="$(json_get_string service "$h_resp")"
  [ "$h_ok" = "true" ] && [ "$h_service" = "pairing" ]
}

probe_list_models_once() {
  l_host="$(trim "${1:-}")"
  l_grpc_port="$(uint_or_default "${2:-50051}" "50051")"
  l_token="$(trim "${3:-}")"
  l_device_id="$(trim "${4:-}")"
  l_user_id="$(trim "${5:-}")"
  l_app_id="$(trim "${6:-}")"
  l_tls_mode="$(trim "${7:-}")"
  l_tls_server_name="$(trim "${8:-}")"
  l_tls_ca_cert_path="$(trim "${9:-}")"
  l_tls_client_cert_path="$(trim "${10:-}")"
  l_tls_client_key_path="$(trim "${11:-}")"
  [ -n "$l_host" ] || return 1

  l_kit_dir="${AXHUBCTL_CLIENT_KIT_DIR:-$STATE_DIR/client_kit}"
  [ -f "$l_kit_dir/hub_grpc_server/src/list_models_client.js" ] || return 2

  l_node_bin="$(resolve_node_bin "$l_kit_dir" || true)"
  [ -n "$l_node_bin" ] || return 2
  [ -n "$l_token" ] || return 2

  PROBE_LAST_ERROR=""
  l_rc=0
  l_out="$(
    HUB_HOST="$l_host" \
    HUB_PORT="$l_grpc_port" \
    HUB_CLIENT_TOKEN="$l_token" \
    HUB_DEVICE_ID="$l_device_id" \
    HUB_USER_ID="$l_user_id" \
    HUB_APP_ID="$l_app_id" \
    HUB_GRPC_TLS_MODE="$l_tls_mode" \
    HUB_GRPC_TLS_SERVER_NAME="$l_tls_server_name" \
    HUB_GRPC_TLS_CA_CERT_PATH="$l_tls_ca_cert_path" \
    HUB_GRPC_TLS_CLIENT_CERT_PATH="$l_tls_client_cert_path" \
    HUB_GRPC_TLS_CLIENT_KEY_PATH="$l_tls_client_key_path" \
    "$l_node_bin" "$l_kit_dir/hub_grpc_server/src/list_models_client.js" 2>&1
  )" || l_rc=$?
  [ "$l_rc" -eq 0 ] && return 0

  if [ -n "$(trim "$l_out")" ]; then
    PROBE_LAST_ERROR="$(printf '%s\n' "$l_out" | sed -n '1,4p')"
  else
    case "$l_rc" in
      126) PROBE_LAST_ERROR="node runtime is not executable: $l_node_bin" ;;
      127) PROBE_LAST_ERROR="node runtime not found: $l_node_bin" ;;
      130|134|137|139|143)
        PROBE_LAST_ERROR="node runtime killed (exit=$l_rc, node=$l_node_bin)"
        ;;
    esac
  fi

  case "$l_rc" in
    # Treat process-level runtime failures as "gRPC probe unavailable" and
    # fall back to pairing health for connect readiness.
    126|127|130|134|137|139|143) return 2 ;;
  esac
  return "$l_rc"
}

case "$cmd" in
  remote)
    # Convenience wrapper: run any command using the local tunnel override (~/.axhub/tunnel.env).
    sub="${1:-}"
    [ -n "$(trim "$sub")" ] || die "remote: missing subcommand (try: $0 remote list-models)"
    shift || true
    export AXHUBCTL_USE_TUNNEL=1
    if [ -x "$0" ]; then
      exec "$0" "$sub" "$@"
    else
      exec /bin/sh "$0" "$sub" "$@"
    fi
    ;;

  discover)
    PAIRING_PORT="50052"
    pairing_port_set="0"
    timeout_sec="2"
    hints_csv=""
    quiet="0"

    while [ "$#" -gt 0 ]; do
      case "$1" in
        --pairing-port) PAIRING_PORT="${2:-}"; pairing_port_set="1"; shift 2 ;;
        --timeout-sec) timeout_sec="${2:-}"; shift 2 ;;
        --hints) hints_csv="${2:-}"; shift 2 ;;
        --quiet) quiet="1"; shift 1 ;;
        *) die "unknown arg: $1" ;;
      esac
    done

    PAIRING_PORT="$(uint_or_default "$PAIRING_PORT" "50052")"
    timeout_sec="$(uint_or_default "$timeout_sec" "2")"

    discovered="$(discover_hub_endpoint "$PAIRING_PORT" "$timeout_sec" "$hints_csv" "$pairing_port_set" || true)"
    [ -n "$discovered" ] || die "hub discovery failed (checked hints/axhub.local/default gateway/local host)"

    found_host="$(trim "${discovered%%|*}")"
    tail1="${discovered#*|}"
    found_pairing_port="$(trim "${tail1%%|*}")"
    tail2="${tail1#*|}"
    found_grpc_port="$(trim "${tail2%%|*}")"
    tail3="${tail2#*|}"
    found_tls_mode="$(trim "${tail3%%|*}")"
    tail4="${tail3#*|}"
    found_tls_name="$(trim "${tail4%%|*}")"
    tail5="${tail4#*|}"
    found_internet_host="$(trim "${tail5%%|*}")"
    tail6="${tail5#*|}"
    found_hub_instance_id="$(trim "${tail6%%|*}")"
    tail7="${tail6#*|}"
    found_lan_discovery_name="$(trim "${tail7%%|*}")"
    tail8="${tail7#*|}"
    found_pairing_profile_epoch="$(trim "${tail8%%|*}")"
    found_route_pack_version="$(trim "${tail8#*|}")"

    found_pairing_port="$(uint_or_default "$found_pairing_port" "$PAIRING_PORT")"
    found_grpc_port="$(uint_or_default "$found_grpc_port" "50051")"
    [ -n "$found_host" ] || die "hub discovery returned empty host"

    persist_discovery_result "$found_host" "$found_pairing_port" "$found_grpc_port" "$found_internet_host" "$found_hub_instance_id" "$found_lan_discovery_name" "$found_pairing_profile_epoch" "$found_route_pack_version" || true

    if [ "$quiet" = "1" ]; then
      echo "$found_host"
      exit 0
    fi

    echo "Discovered Hub:"
    echo "  host         : $found_host"
    echo "  pairing_port : $found_pairing_port"
    echo "  grpc_port    : $found_grpc_port"
    if [ -n "$found_tls_mode" ]; then
      echo "  tls_mode     : $found_tls_mode"
    fi
    if [ -n "$found_tls_name" ]; then
      echo "  tls_server   : $found_tls_name"
    fi
    if [ -n "$found_internet_host" ]; then
      echo "  internet_host: $found_internet_host"
    fi
    if [ -n "$found_hub_instance_id" ]; then
      echo "  hub_instance_id: $found_hub_instance_id"
    fi
    if [ -n "$found_lan_discovery_name" ]; then
      echo "  lan_discovery_name: $found_lan_discovery_name"
    fi
    if [ -n "$found_pairing_profile_epoch" ]; then
      echo "  pairing_profile_epoch: $found_pairing_profile_epoch"
    fi
    if [ -n "$found_route_pack_version" ]; then
      echo "  route_pack_version: $found_route_pack_version"
    fi
    echo "Saved state: $PAIRING_ENV"
    ;;

  bootstrap)
    # One-shot flow: knock -> wait -> install-client.
    HUB_HOST="auto"
    PAIRING_PORT="50052"
    pairing_port_set="0"
    GRPC_PORT="50051"
    grpc_port_set="0"
    APP_ID="ax_terminal"
    DEVICE_NAME=""
    REQUESTED_SCOPES=""
    INVITE_TOKEN=""
    found_internet_host=""
    found_hub_instance_id=""
    found_lan_discovery_name=""
    found_pairing_profile_epoch=""
    found_route_pack_version=""
    timeout_sec="900"
    interval_sec="2"
    client_kit_policy="best_effort"

    while [ "$#" -gt 0 ]; do
      case "$1" in
        --hub) HUB_HOST="${2:-}"; shift 2 ;;
        --pairing-port) PAIRING_PORT="${2:-}"; pairing_port_set="1"; shift 2 ;;
        --grpc-port) GRPC_PORT="${2:-}"; grpc_port_set="1"; shift 2 ;;
        --app-id) APP_ID="${2:-}"; shift 2 ;;
        --device-name) DEVICE_NAME="${2:-}"; shift 2 ;;
        --requested-scopes) REQUESTED_SCOPES="${2:-}"; shift 2 ;;
        --invite-token) INVITE_TOKEN="${2:-}"; shift 2 ;;
        --timeout-sec) timeout_sec="${2:-}"; shift 2 ;;
        --interval-sec) interval_sec="${2:-}"; shift 2 ;;
        --require-client-kit) client_kit_policy="required"; shift 1 ;;
        --skip-install-client) client_kit_policy="skip"; shift 1 ;;
        *) die "unknown arg: $1" ;;
      esac
    done

    HUB_HOST="$(trim "$HUB_HOST")"
    [ -n "$HUB_HOST" ] || HUB_HOST="auto"
    PAIRING_PORT="$(uint_or_default "$PAIRING_PORT" "50052")"
    GRPC_PORT="$(uint_or_default "$GRPC_PORT" "50051")"

    if [ "$HUB_HOST" = "auto" ]; then
      discovered="$(discover_hub_endpoint "$PAIRING_PORT" "2" "" "$pairing_port_set" || true)"
      [ -n "$discovered" ] || die "bootstrap discovery failed (use --hub <host> or set HUB_DISCOVERY_HINTS)"
      HUB_HOST="$(trim "${discovered%%|*}")"
      tail1="${discovered#*|}"
      found_pairing_port="$(trim "${tail1%%|*}")"
      tail2="${tail1#*|}"
      found_grpc_port="$(trim "${tail2%%|*}")"
      tail3="${tail2#*|}"
      tail4="${tail3#*|}"
      tail5="${tail4#*|}"
      found_internet_host="$(trim "${tail5%%|*}")"
      tail6="${tail5#*|}"
      found_hub_instance_id="$(trim "${tail6%%|*}")"
      tail7="${tail6#*|}"
      found_lan_discovery_name="$(trim "${tail7%%|*}")"
      tail8="${tail7#*|}"
      found_pairing_profile_epoch="$(trim "${tail8%%|*}")"
      found_route_pack_version="$(trim "${tail8#*|}")"
      [ -n "$HUB_HOST" ] || die "bootstrap discovery returned empty host"
      if [ "$pairing_port_set" != "1" ]; then
        PAIRING_PORT="$(uint_or_default "$found_pairing_port" "$PAIRING_PORT")"
      fi
      if [ "$grpc_port_set" != "1" ]; then
        GRPC_PORT="$(uint_or_default "$found_grpc_port" "$GRPC_PORT")"
      fi
      if [ -n "$found_internet_host" ]; then
        export AXHUB_INTERNET_HOST="$found_internet_host"
      fi
      persist_discovery_result "$HUB_HOST" "$PAIRING_PORT" "$GRPC_PORT" "$found_internet_host" "$found_hub_instance_id" "$found_lan_discovery_name" "$found_pairing_profile_epoch" "$found_route_pack_version" || true
      echo "Discovered Hub: ${HUB_HOST} (pairing=${PAIRING_PORT}, grpc=${GRPC_PORT})"
    fi

    self="$0"
    if [ -n "$(trim "$INVITE_TOKEN")" ]; then
      run_self knock --hub "$HUB_HOST" --pairing-port "$PAIRING_PORT" --grpc-port "$GRPC_PORT" --app-id "$APP_ID" --device-name "$DEVICE_NAME" --requested-scopes "$REQUESTED_SCOPES" --invite-token "$INVITE_TOKEN"
    else
      run_self knock --hub "$HUB_HOST" --pairing-port "$PAIRING_PORT" --grpc-port "$GRPC_PORT" --app-id "$APP_ID" --device-name "$DEVICE_NAME" --requested-scopes "$REQUESTED_SCOPES"
    fi
    run_self wait --hub "$HUB_HOST" --pairing-port "$PAIRING_PORT" --grpc-port "$GRPC_PORT" --timeout-sec "$timeout_sec" --interval-sec "$interval_sec"
    if [ "$client_kit_policy" = "skip" ]; then
      echo "Skip downloading client kit (--skip-install-client)."
    else
      install_rc=0
      install_out="$(run_self install-client --hub "$HUB_HOST" --pairing-port "$PAIRING_PORT" 2>&1)" || install_rc=$?
      if [ "$install_rc" -eq 0 ]; then
        echo "$install_out"
      else
        echo "$install_out" >&2
        if [ "$client_kit_policy" = "required" ]; then
          die "install-client failed (required)"
        fi
        # Best effort by default: pairing/connect can still work without bundled client kit.
        echo "Warning: install-client failed; continuing with pairing-only mode." >&2
      fi
    fi

    echo ""
    echo "Try:"
    echo "  $self list-models"
    echo "  $self new-chat && $self chat --model <model_id>"
    echo "  $self chat --model <model_id> --prompt \"hello\" --max-tokens 64"
    echo ""
    echo "Remote (VPN/Tunnel) Mode 3:"
    echo "  # Start a local TCP tunnel; keep gRPC clients on 127.0.0.1"
    echo "  $self tunnel --hub <hub_vpn_or_tailnet_host> --grpc-port $GRPC_PORT --local-port $GRPC_PORT"
    echo "  # (macOS) Install as a background service:"
    echo "  $self tunnel --hub <hub_vpn_or_tailnet_host> --grpc-port $GRPC_PORT --local-port $GRPC_PORT --install"
    echo "  # Status:"
    echo "  $self tunnel --status"
    echo "  # Use the tunnel:"
    echo "  $self remote list-models"
    ;;

  knock|pair)
    HUB_HOST="auto"
    PAIRING_PORT="50052"
    pairing_port_set="0"
    GRPC_PORT="50051"
    APP_ID="ax_terminal"
    DEVICE_NAME=""
    REQUESTED_SCOPES=""
    INVITE_TOKEN=""
    found_internet_host=""

    while [ "$#" -gt 0 ]; do
      case "$1" in
        --hub) HUB_HOST="${2:-}"; shift 2 ;;
        --pairing-port) PAIRING_PORT="${2:-}"; pairing_port_set="1"; shift 2 ;;
        --grpc-port) GRPC_PORT="${2:-}"; shift 2 ;;
        --app-id) APP_ID="${2:-}"; shift 2 ;;
        --device-name) DEVICE_NAME="${2:-}"; shift 2 ;;
        --requested-scopes) REQUESTED_SCOPES="${2:-}"; shift 2 ;;
        --invite-token) INVITE_TOKEN="${2:-}"; shift 2 ;;
        *) die "unknown arg: $1" ;;
      esac
    done

    HUB_HOST="$(trim "$HUB_HOST")"
    [ -n "$HUB_HOST" ] || HUB_HOST="auto"
    PAIRING_PORT="$(uint_or_default "$PAIRING_PORT" "50052")"
    GRPC_PORT="$(uint_or_default "$GRPC_PORT" "50051")"

    found_internet_host=""
    found_hub_instance_id=""
    found_lan_discovery_name=""
    found_pairing_profile_epoch=""
    found_route_pack_version=""
    if [ "$HUB_HOST" = "auto" ]; then
      discovered="$(discover_hub_endpoint "$PAIRING_PORT" "2" "" "$pairing_port_set" || true)"
      [ -n "$discovered" ] || die "knock discovery failed (use --hub <host> or set HUB_DISCOVERY_HINTS)"
      HUB_HOST="$(trim "${discovered%%|*}")"
      tail1="${discovered#*|}"
      found_pairing_port="$(trim "${tail1%%|*}")"
      tail2="${tail1#*|}"
      found_grpc_port="$(trim "${tail2%%|*}")"
      tail3="${tail2#*|}"
      tail4="${tail3#*|}"
    tail5="${tail4#*|}"
    found_internet_host="$(trim "${tail5%%|*}")"
    tail6="${tail5#*|}"
    found_hub_instance_id="$(trim "${tail6%%|*}")"
    tail7="${tail6#*|}"
    found_lan_discovery_name="$(trim "${tail7%%|*}")"
    tail8="${tail7#*|}"
    found_pairing_profile_epoch="$(trim "${tail8%%|*}")"
    found_route_pack_version="$(trim "${tail8#*|}")"
    [ -n "$HUB_HOST" ] || die "knock discovery returned empty host"
    PAIRING_PORT="$(uint_or_default "$found_pairing_port" "$PAIRING_PORT")"
    GRPC_PORT="$(uint_or_default "$found_grpc_port" "$GRPC_PORT")"
    echo "Discovered Hub: ${HUB_HOST} (pairing=${PAIRING_PORT}, grpc=${GRPC_PORT})"
  fi

    secret="$(random_secret)"
    [ -n "$secret" ] || die "failed to generate pairing secret"

    scopes_json=""
    if [ -n "$(trim "$REQUESTED_SCOPES")" ]; then
      scopes_json="["
      first="1"
      oldIFS="$IFS"
      IFS=","
      # shellcheck disable=SC2086
      set -- $REQUESTED_SCOPES
      IFS="$oldIFS"
      for raw in "$@"; do
        s="$(trim "$raw")"
        [ -n "$s" ] || continue
        if [ "$first" = "1" ]; then
          first="0"
        else
          scopes_json="${scopes_json},"
        fi
        scopes_json="${scopes_json}\"$(json_escape "$s")\""
      done
      scopes_json="${scopes_json}]"
    fi

    payload="{\"app_id\":\"$(json_escape "$APP_ID")\",\"device_name\":\"$(json_escape "$DEVICE_NAME")\",\"pairing_secret\":\"$(json_escape "$secret")\""
    if [ -n "$scopes_json" ]; then
      payload="${payload},\"requested_scopes\":${scopes_json}"
    fi
    if [ -n "$(trim "$INVITE_TOKEN")" ]; then
      payload="${payload},\"invite_token\":\"$(json_escape "$INVITE_TOKEN")\""
    fi

    # Optional: provide a CSR so the Hub can issue an mTLS client certificate.
    # This does not leak the private key (it stays on the terminal device).
    tls_csr_b64="$(ensure_tls_key_and_csr_b64 || true)"
    if [ -n "$(trim "$tls_csr_b64")" ]; then
      payload="${payload},\"tls_csr_b64\":\"$(json_escape "$tls_csr_b64")\""
    fi
    payload="${payload}}"

    url="http://${HUB_HOST}:${PAIRING_PORT}/pairing/requests"
    req_tmpdir="$(mktemp_dir)"
    req_body="$req_tmpdir/pairing_request.json"
    req_err="$req_tmpdir/pairing_request.err"
    http_code="$(curl -sS -o "$req_body" -w '%{http_code}' -X POST "$url" -H 'Content-Type: application/json' -d "$payload" 2>"$req_err")" || {
      err="$(cat "$req_err" 2>/dev/null || true)"
      rm -rf "$req_tmpdir" 2>/dev/null || true
      if echo "$err" | grep -q "HTTP/0\\.9"; then
        die "request failed (did you use the gRPC port? pairing port is usually HUB_PORT+1, e.g. 50052). curl: $err"
      fi
      die "request failed: $err"
    }
    resp="$(cat "$req_body" 2>/dev/null || true)"
    case "$http_code" in
      2??) ;;
      *)
        detail="$(format_http_error_detail "request" "$resp" || true)"
        rm -rf "$req_tmpdir" 2>/dev/null || true
        if [ -n "$(trim "$detail")" ]; then
          die "$detail"
        fi
        die "request failed (HTTP $http_code): $(trim "$resp")"
        ;;
    esac
    rm -rf "$req_tmpdir" 2>/dev/null || true
    rid="$(json_get_string pairing_request_id "$resp")"
    status="$(json_get_string status "$resp")"
    [ -n "$rid" ] || die "could not parse pairing_request_id (response: $resp)"

    write_pairing_env_state "$HUB_HOST" "$PAIRING_PORT" "$GRPC_PORT" "$APP_ID" "$DEVICE_NAME" "$rid" "$secret" "$found_internet_host" "$found_hub_instance_id" "$found_lan_discovery_name" "$found_pairing_profile_epoch" "$found_route_pack_version"

    echo "Pairing request created: $rid (status=${status:-pending})"
    echo "Saved state: $PAIRING_ENV"
    echo "Next: wait for Hub approval, then run:"
    echo "  $0 wait"
    ;;

  wait)
    # Defaults (loaded from state file if present).
    HUB_HOST=""
    PAIRING_PORT=""
    GRPC_PORT=""
    rid=""
    secret=""
    timeout_sec="900"
    interval_sec="2"
    pairing_port_set="0"

    if [ -f "$PAIRING_ENV" ]; then
      # shellcheck disable=SC1090
      . "$PAIRING_ENV"
      HUB_HOST="${AXHUB_HUB_HOST:-}"
      PAIRING_PORT="${AXHUB_PAIRING_PORT:-}"
      GRPC_PORT="${AXHUB_GRPC_PORT:-}"
      rid="${AXHUB_PAIRING_REQUEST_ID:-}"
      secret="${AXHUB_PAIRING_SECRET:-}"
    fi

    while [ "$#" -gt 0 ]; do
      case "$1" in
        --hub) HUB_HOST="${2:-}"; shift 2 ;;
        --pairing-port) PAIRING_PORT="${2:-}"; pairing_port_set="1"; shift 2 ;;
        --grpc-port) GRPC_PORT="${2:-}"; shift 2 ;;
        --id) rid="${2:-}"; shift 2 ;;
        --secret) secret="${2:-}"; shift 2 ;;
        --timeout-sec) timeout_sec="${2:-}"; shift 2 ;;
        --interval-sec) interval_sec="${2:-}"; shift 2 ;;
        *) die "unknown arg: $1" ;;
      esac
    done

    HUB_HOST="$(trim "$HUB_HOST")"
    [ -n "$HUB_HOST" ] || HUB_HOST="auto"
    PAIRING_PORT="$(uint_or_default "${PAIRING_PORT:-50052}" "50052")"
    GRPC_PORT="$(uint_or_default "${GRPC_PORT:-50051}" "50051")"
    timeout_sec="$(uint_or_default "$timeout_sec" "900")"
    interval_sec="$(uint_or_default "$interval_sec" "2")"
    [ "$interval_sec" -gt 0 ] || interval_sec="2"

    if [ "$HUB_HOST" = "auto" ]; then
      discovered="$(discover_hub_endpoint "$PAIRING_PORT" "2" "" "$pairing_port_set" || true)"
      [ -n "$discovered" ] || die "wait discovery failed (use --hub <host> or run knock first)"
      HUB_HOST="$(trim "${discovered%%|*}")"
      tail1="${discovered#*|}"
      found_pairing_port="$(trim "${tail1%%|*}")"
      tail2="${tail1#*|}"
      found_grpc_port="$(trim "${tail2%%|*}")"
      tail3="${tail2#*|}"
      tail4="${tail3#*|}"
      tail5="${tail4#*|}"
      found_internet_host="$(trim "${tail5%%|*}")"
      tail6="${tail5#*|}"
      found_hub_instance_id="$(trim "${tail6%%|*}")"
      tail7="${tail6#*|}"
      found_lan_discovery_name="$(trim "${tail7%%|*}")"
      tail8="${tail7#*|}"
      found_pairing_profile_epoch="$(trim "${tail8%%|*}")"
      found_route_pack_version="$(trim "${tail8#*|}")"
      PAIRING_PORT="$(uint_or_default "$found_pairing_port" "$PAIRING_PORT")"
      GRPC_PORT="$(uint_or_default "$found_grpc_port" "$GRPC_PORT")"
      persist_discovery_result "$HUB_HOST" "$PAIRING_PORT" "$GRPC_PORT" "$found_internet_host" "$found_hub_instance_id" "$found_lan_discovery_name" "$found_pairing_profile_epoch" "$found_route_pack_version" || true
      echo "Discovered Hub: ${HUB_HOST} (pairing=${PAIRING_PORT}, grpc=${GRPC_PORT})"
    fi

    rid="$(trim "$rid")"
    secret="$(trim "$secret")"
    [ -n "$rid" ] || die "--id is required (or run from a previous knock)"
    [ -n "$secret" ] || die "--secret is required (or run from a previous knock)"

    url="http://${HUB_HOST}:${PAIRING_PORT}/pairing/requests/${rid}"
    start_ts="$(date +%s)"

    echo "Waiting for approval… (request_id=$rid)"
    while :; do
      resp="$(curl -fsS "$url" -H "X-Pairing-Secret: $secret" 2>/dev/null || true)"
      if [ -n "$resp" ]; then
        status="$(json_get_string status "$resp")"
        if [ "$status" = "approved" ]; then
          tok="$(json_get_string client_token "$resp")"
          dev_id="$(json_get_string device_id "$resp")"
          user_id_from_resp="$(json_get_string user_id "$resp")"
          pairing_profile_epoch="$(trim "$(json_get_number pairing_profile_epoch "$resp")")"
          route_pack_version="$(trim "$(json_get_string route_pack_version "$resp")")"
          [ -n "$tok" ] || die "approved but missing client_token (response: $resp)"

          # Optional TLS bootstrap (Hub may be configured for TLS/mTLS).
          tls_mode="$(trim "$(json_get_string mode "$resp")")"
          case "$tls_mode" in
            ""|insecure) tls_mode="insecure" ;;
            tls|mtls) ;;
            *)
              echo "warning: unknown tls mode from hub ('$tls_mode'); fallback to insecure" >&2
              tls_mode="insecure"
              ;;
          esac
          tls_server_name="$(trim "$(json_get_string server_name "$resp")")"
          [ -n "$tls_server_name" ] || tls_server_name="axhub"
          ca_b64="$(json_get_string ca_cert_b64 "$resp")"
          client_b64="$(json_get_string client_cert_b64 "$resp")"

          tls_dir="$STATE_DIR/tls"
          ca_path="$tls_dir/ca.cert.pem"
          client_cert_path="$tls_dir/client.cert.pem"
          client_key_path="$tls_dir/client.key.pem"
          profile_ca_path=""
          profile_client_cert_path=""
          profile_client_key_path=""

          if [ "$tls_mode" = "tls" ] || [ "$tls_mode" = "mtls" ]; then
            [ -n "$(trim "$ca_b64")" ] || die "approved but missing ca_cert_b64 (response: $resp)"
            base64_decode_to_file "$ca_b64" "$ca_path"
            chmod 644 "$ca_path" 2>/dev/null || true
            profile_ca_path="$ca_path"

            if [ "$tls_mode" = "mtls" ]; then
              [ -n "$(trim "$client_b64")" ] || die "approved but missing client_cert_b64 (response: $resp)"
              [ -f "$client_key_path" ] || die "missing client private key (expected at $client_key_path); re-run: $0 knock"
              base64_decode_to_file "$client_b64" "$client_cert_path"
              chmod 644 "$client_cert_path" 2>/dev/null || true
              chmod 600 "$client_key_path" 2>/dev/null || true
              profile_client_cert_path="$client_cert_path"
              profile_client_key_path="$client_key_path"
            fi
          fi

          write_hub_env_state "$HUB_HOST" "$GRPC_PORT" "$tok" "${dev_id:-}" "${user_id_from_resp:-}" "${AXHUB_APP_ID:-ax_terminal}" "$tls_mode" "$tls_server_name" "$profile_ca_path" "$profile_client_cert_path" "$profile_client_key_path"
          write_connection_profile "$HUB_HOST" "$GRPC_PORT" "$PAIRING_PORT" "${dev_id:-}" "$tls_mode" "$tls_server_name" "$profile_ca_path" "$profile_client_cert_path" "$profile_client_key_path" "$pairing_profile_epoch" "$route_pack_version"
          persist_discovery_result "$HUB_HOST" "$PAIRING_PORT" "$GRPC_PORT" "${AXHUB_INTERNET_HOST:-}" "${AXHUB_HUB_INSTANCE_ID:-}" "${AXHUB_LAN_DISCOVERY_NAME:-}" "$pairing_profile_epoch" "$route_pack_version" || true
          echo "Approved."
          echo "Saved env: $HUB_ENV"
          echo "Saved connection profile: $CONNECTION_JSON"
          echo "Use it with:"
          echo "  . \"$HUB_ENV\""
          echo "Next (download client kit from Hub):"
          echo "  $0 install-client"
          exit 0
        fi
        if [ "$status" = "denied" ]; then
          reason="$(json_get_string deny_reason "$resp")"
          die "denied: ${reason:-unknown}"
        fi
      fi

      now_ts="$(date +%s)"
      elapsed="$((now_ts - start_ts))"
      if [ "$elapsed" -ge "$timeout_sec" ]; then
        die "timeout waiting for approval (${timeout_sec}s)"
      fi
      sleep "$interval_sec"
    done
    ;;

  connect)
    HUB_HOST=""
    GRPC_PORT=""
    PAIRING_PORT="50052"
    pairing_port_set="0"
    auto_reconnect="0"
    max_backoff_sec="30"
    max_failures="0" # 0 = infinite
    timeout_sec="2"
    quiet="0"
    grpc_port_set="0"

    hub_token=""
    hub_device_id="terminal_device"
    hub_user_id=""
    hub_app_id="ax_terminal"
    hub_tls_mode=""
    hub_tls_server_name=""
    hub_tls_ca_path=""
    hub_tls_client_cert_path=""
    hub_tls_client_key_path=""

    if [ -f "$HUB_ENV" ]; then
      # shellcheck disable=SC1090
      . "$HUB_ENV"
      HUB_HOST="${HUB_HOST:-}"
      GRPC_PORT="${HUB_PORT:-$GRPC_PORT}"
      hub_token="${HUB_CLIENT_TOKEN:-$hub_token}"
      hub_device_id="${HUB_DEVICE_ID:-$hub_device_id}"
      hub_user_id="${HUB_USER_ID:-$hub_user_id}"
      hub_app_id="${HUB_APP_ID:-$hub_app_id}"
      hub_tls_mode="${HUB_GRPC_TLS_MODE:-$hub_tls_mode}"
      hub_tls_server_name="${HUB_GRPC_TLS_SERVER_NAME:-$hub_tls_server_name}"
      hub_tls_ca_path="${HUB_GRPC_TLS_CA_CERT_PATH:-$hub_tls_ca_path}"
      hub_tls_client_cert_path="${HUB_GRPC_TLS_CLIENT_CERT_PATH:-$hub_tls_client_cert_path}"
      hub_tls_client_key_path="${HUB_GRPC_TLS_CLIENT_KEY_PATH:-$hub_tls_client_key_path}"
    fi

    if [ -f "$PAIRING_ENV" ]; then
      # shellcheck disable=SC1090
      . "$PAIRING_ENV"
      if [ -z "$(trim "$HUB_HOST")" ]; then
        HUB_HOST="${AXHUB_HUB_HOST:-$HUB_HOST}"
      fi
      PAIRING_PORT="${AXHUB_PAIRING_PORT:-$PAIRING_PORT}"
      if [ -z "$(trim "$GRPC_PORT")" ]; then
        GRPC_PORT="${AXHUB_GRPC_PORT:-$GRPC_PORT}"
      fi
      if [ -z "$(trim "$hub_app_id")" ]; then
        hub_app_id="${AXHUB_APP_ID:-$hub_app_id}"
      fi
    fi

    while [ "$#" -gt 0 ]; do
      case "$1" in
        --hub) HUB_HOST="${2:-}"; shift 2 ;;
        --grpc-port) GRPC_PORT="${2:-}"; grpc_port_set="1"; shift 2 ;;
        --pairing-port) PAIRING_PORT="${2:-}"; pairing_port_set="1"; shift 2 ;;
        --auto-reconnect) auto_reconnect="1"; shift 1 ;;
        --max-backoff-sec) max_backoff_sec="${2:-}"; shift 2 ;;
        --max-failures) max_failures="${2:-}"; shift 2 ;;
        --timeout-sec) timeout_sec="${2:-}"; shift 2 ;;
        --quiet) quiet="1"; shift 1 ;;
        *) die "unknown arg: $1" ;;
      esac
    done

    HUB_HOST="$(trim "$HUB_HOST")"
    [ -n "$HUB_HOST" ] || HUB_HOST="auto"
    GRPC_PORT="$(uint_or_default "${GRPC_PORT:-50051}" "50051")"
    PAIRING_PORT="$(uint_or_default "${PAIRING_PORT:-50052}" "50052")"
    max_backoff_sec="$(uint_or_default "$max_backoff_sec" "30")"
    [ "$max_backoff_sec" -gt 0 ] || max_backoff_sec="30"
    max_failures="$(uint_or_default "$max_failures" "0")"
    timeout_sec="$(uint_or_default "$timeout_sec" "2")"
    [ "$timeout_sec" -gt 0 ] || timeout_sec="2"

    # Convenience: allow --hub 192.168.1.10:50051 when --grpc-port is omitted.
    if [ "$grpc_port_set" != "1" ] && [ "$HUB_HOST" != "auto" ] && echo "$HUB_HOST" | grep -q ':[0-9][0-9]*$'; then
      maybe_host="${HUB_HOST%:*}"
      maybe_port="${HUB_HOST##*:}"
      maybe_port="$(uint_or_default "$maybe_port" "$GRPC_PORT")"
      if [ -n "$(trim "$maybe_host")" ]; then
        HUB_HOST="$maybe_host"
        GRPC_PORT="$maybe_port"
      fi
    fi

    attempt=0
    backoff_sec="1"
    while :; do
      target_host="$HUB_HOST"
      target_pairing_port="$PAIRING_PORT"
      target_grpc_port="$GRPC_PORT"
      last_error="unknown"

      if [ "$target_host" = "auto" ]; then
        discovered="$(discover_hub_endpoint "$target_pairing_port" "$timeout_sec" "" "$pairing_port_set" || true)"
        if [ -n "$discovered" ]; then
          target_host="$(trim "${discovered%%|*}")"
          tail1="${discovered#*|}"
          discovered_pairing_port="$(trim "${tail1%%|*}")"
          tail2="${tail1#*|}"
          discovered_grpc_port="$(trim "${tail2%%|*}")"
          target_pairing_port="$(uint_or_default "$discovered_pairing_port" "$target_pairing_port")"
          target_grpc_port="$(uint_or_default "$discovered_grpc_port" "$target_grpc_port")"
          persist_discovery_result "$target_host" "$target_pairing_port" "$target_grpc_port" || true
        else
          last_error="discovery_failed"
        fi
      fi

      if [ "$last_error" != "discovery_failed" ]; then
        probe_mode=""
        probe_rc=0
        probe_list_models_once \
          "$target_host" \
          "$target_grpc_port" \
          "$hub_token" \
          "$hub_device_id" \
          "$hub_user_id" \
          "$hub_app_id" \
          "$hub_tls_mode" \
          "$hub_tls_server_name" \
          "$hub_tls_ca_path" \
          "$hub_tls_client_cert_path" \
          "$hub_tls_client_key_path" || probe_rc=$?

        if [ "$probe_rc" -eq 0 ]; then
          probe_mode="grpc"
        elif [ "$probe_rc" -eq 2 ]; then
          if probe_pairing_health "$target_host" "$target_pairing_port" "$timeout_sec"; then
            probe_mode="pairing"
          else
            last_error="pairing_health_failed"
          fi
        else
          probe_err="$(trim "${PROBE_LAST_ERROR:-}")"
          if [ -n "$probe_err" ] && [ "$quiet" != "1" ]; then
            echo "Probe error: $probe_err"
          fi
          if echo "$probe_err" | grep -Eiq "node_runtime_killed|node runtime killed|exit=137|exit=134"; then
            last_error="node_runtime_killed"
          elif echo "$probe_err" | grep -Eiq "alert certificate required|tlsv13 alert certificate required|peer did not return a certificate|client certificate required|certificate required"; then
            last_error="mtls_client_certificate_required"
          elif echo "$probe_err" | grep -Eiq "unauthenticated|invalid token|permission denied"; then
            last_error="unauthenticated"
          elif echo "$probe_err" | grep -Eiq "forbidden|permission_denied|not authorized"; then
            last_error="forbidden"
          elif echo "$probe_err" | grep -Eiq "certificate|tls|ssl"; then
            last_error="tls_error"
          elif echo "$probe_err" | grep -Eiq "unavailable|failed to connect|connection refused|deadline exceeded|timeout"; then
            last_error="grpc_unavailable"
          else
            last_error="grpc_probe_failed"
          fi
        fi

        if [ -n "$probe_mode" ]; then
          if [ "$probe_mode" = "grpc" ] && [ -n "$hub_token" ]; then
            write_hub_env_state "$target_host" "$target_grpc_port" "$hub_token" "$hub_device_id" "$hub_user_id" "$hub_app_id" "$hub_tls_mode" "$hub_tls_server_name" "$hub_tls_ca_path" "$hub_tls_client_cert_path" "$hub_tls_client_key_path"
          fi
          write_connection_profile "$target_host" "$target_grpc_port" "$target_pairing_port" "$hub_device_id" "${hub_tls_mode:-insecure}" "$hub_tls_server_name" "$hub_tls_ca_path" "$hub_tls_client_cert_path" "$hub_tls_client_key_path"
          if [ "$quiet" != "1" ]; then
            echo "Connected (${probe_mode}): ${target_host}:${target_grpc_port}"
            if [ "$probe_mode" = "pairing" ]; then
              echo "Note: gRPC auth probe skipped (missing client kit/token)."
            fi
          fi
          exit 0
        fi
      fi

      if [ "$auto_reconnect" != "1" ]; then
        die "connect failed (${last_error}). Try: $0 bootstrap --hub auto"
      fi

      attempt=$((attempt + 1))
      if [ "$max_failures" -gt 0 ] && [ "$attempt" -ge "$max_failures" ]; then
        die "connect failed after ${attempt} retries (${last_error}). Try: $0 knock --hub auto && $0 wait"
      fi

      jitter="$((attempt % 3))"
      sleep_sec=$((backoff_sec + jitter))
      if [ "$sleep_sec" -gt "$max_backoff_sec" ]; then
        sleep_sec="$max_backoff_sec"
      fi
      if [ "$quiet" != "1" ]; then
        echo "Reconnect retry #${attempt} in ${sleep_sec}s (${last_error})"
      fi
      sleep "$sleep_sec"

      backoff_sec=$((backoff_sec * 2))
      if [ "$backoff_sec" -gt "$max_backoff_sec" ]; then
        backoff_sec="$max_backoff_sec"
      fi
    done
    ;;

  install-client)
    # Download a self-contained client kit (hub_grpc_server + protocol + node_modules) from the Hub.
    HUB_HOST=""
    PAIRING_PORT="50052"
    KIT_DIR="${AXHUBCTL_CLIENT_KIT_DIR:-$STATE_DIR/client_kit}"

    if [ -f "$PAIRING_ENV" ]; then
      # shellcheck disable=SC1090
      . "$PAIRING_ENV"
      HUB_HOST="${AXHUB_HUB_HOST:-$HUB_HOST}"
      PAIRING_PORT="${AXHUB_PAIRING_PORT:-$PAIRING_PORT}"
    fi

    while [ "$#" -gt 0 ]; do
      case "$1" in
        --hub) HUB_HOST="${2:-}"; shift 2 ;;
        --pairing-port) PAIRING_PORT="${2:-}"; shift 2 ;;
        --dir) KIT_DIR="${2:-}"; shift 2 ;;
        *) die "unknown arg: $1" ;;
      esac
    done

    HUB_HOST="$(trim "$HUB_HOST")"
    [ -n "$HUB_HOST" ] || die "--hub is required (or run after knock)"
    PAIRING_PORT="$(trim "${PAIRING_PORT:-50052}")"
    KIT_DIR="$(trim "$KIT_DIR")"
    [ -n "$KIT_DIR" ] || die "--dir is required"

    need_cmd tar

    info="$(client_kit_info "$HUB_HOST" "$PAIRING_PORT" || true)"
    if [ -z "$info" ]; then
      if install_client_kit_from_local_repo "$KIT_DIR"; then
        echo "Installed client kit from local repo fallback: $KIT_DIR"
        echo "Warning: Hub did not provide /install/axhub_client_kit.*, using local fallback."
        echo "Next:"
        echo "  . \"$HUB_ENV\""
        echo "  $0 list-models"
        exit 0
      fi
      die "client kit not available on Hub yet"
    fi
    kit_url="${info%%|*}"
    kit_sha="${info#*|}"
    [ -n "$kit_url" ] || die "failed to resolve kit_url"
    [ -n "$kit_sha" ] || die "failed to resolve kit_sha256"

    tmpdir="$(mktemp_dir)"
    tmp_tgz="$tmpdir/axhub_client_kit.tgz"

    echo "Downloading client kit…"
    echo "  $kit_url"
    dl_err="$tmpdir/axhub_client_kit.err"
    http_code="$(curl -sS -L -o "$tmp_tgz" -w '%{http_code}' "$kit_url" 2>"$dl_err")" || {
      err="$(cat "$dl_err" 2>/dev/null || true)"
      die "download failed: $err"
    }
    case "$http_code" in
      2??) ;;
      *)
        body="$(cat "$tmp_tgz" 2>/dev/null || true)"
        detail="$(format_http_error_detail "download" "$body" || true)"
        if [ -n "$(trim "$detail")" ]; then
          die "$detail"
        fi
        die "download failed (HTTP $http_code): $(trim "$body")"
        ;;
    esac

    echo "Verifying sha256…"
    sha256_verify "$kit_sha" "$tmp_tgz" || die "sha256 mismatch (refusing to install)"

    echo "Extracting…"
    stage="$tmpdir/stage"
    mkdir -p "$stage"
    tar -xzf "$tmp_tgz" -C "$stage" || die "failed to extract client kit"

    [ -f "$stage/hub_grpc_server/package.json" ] || die "bad kit: missing hub_grpc_server/package.json"
    [ -f "$stage/protocol/hub_protocol_v1.proto" ] || die "bad kit: missing protocol/hub_protocol_v1.proto"

    rm -rf "$KIT_DIR" 2>/dev/null || true
    mkdir -p "$(dirname "$KIT_DIR")"
    mv -f "$stage" "$KIT_DIR"
    clear_quarantine_flags "$KIT_DIR"
    if [ -f "$KIT_DIR/bin/relflowhub_node" ]; then
      sign_binary_if_possible "$KIT_DIR/bin/relflowhub_node"
    fi

    echo "Installed client kit to: $KIT_DIR"
    echo "Next:"
    echo "  . \"$HUB_ENV\""
    echo "  $0 list-models"
    ;;

  new-chat)
    # Create a brand-new conversation identity (thread_key) for Hub-side memory.
    project_id=""
    thread_key=""

    while [ "$#" -gt 0 ]; do
