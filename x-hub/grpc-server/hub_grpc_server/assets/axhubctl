default_gateway_host() {
  gw=""

  if have_cmd route; then
    gw="$(route -n get default 2>/dev/null | awk '/gateway:/{print $2; exit}' || true)"
    gw="$(trim "$gw")"
    [ -n "$gw" ] && {
      echo "$gw"
      return 0
    }
  fi

  if have_cmd ip; then
    gw="$(ip route 2>/dev/null | awk '/^default / {for(i=1;i<=NF;i++){ if($i=="via"){ print $(i+1); exit } }}' || true)"
    gw="$(trim "$gw")"
    [ -n "$gw" ] && {
      echo "$gw"
      return 0
    }
  fi

  if have_cmd netstat; then
    gw="$(netstat -rn 2>/dev/null | awk '($1=="default" || $1=="0.0.0.0"){print $2; exit}' || true)"
    gw="$(trim "$gw")"
    [ -n "$gw" ] && {
      echo "$gw"
      return 0
    }
  fi

  return 1
}

discover_add_bonjour_candidates() {
  d_timeout_sec="$(uint_or_default "${1:-2}" "2")"
  have_cmd dns-sd || return 0

  d_tmp="$(mktemp "${TMPDIR:-/tmp}/axhub_dns_sd.XXXXXX" 2>/dev/null || true)"
  [ -n "$d_tmp" ] || return 0

  dns-sd -B _axhub._tcp local. >"$d_tmp" 2>/dev/null &
  d_pid=$!
  d_started_at="$(date +%s)"

  while :; do
    while IFS= read -r d_line; do
      case "$d_line" in
        *" Add "*"_axhub._tcp."*)
          d_service="$(printf '%s\n' "$d_line" | awk '{print $NF}' | head -n 1)"
          d_service="$(trim "$d_service")"
          [ -n "$d_service" ] && discover_append_unique "${d_service}.local"
          ;;
      esac
    done <"$d_tmp"

    d_now="$(date +%s)"
    [ $((d_now - d_started_at)) -ge "$d_timeout_sec" ] && break
    sleep 1
  done

  kill "$d_pid" >/dev/null 2>&1 || true
  wait "$d_pid" >/dev/null 2>&1 || true
  rm -f "$d_tmp" >/dev/null 2>&1 || true
}

discover_append_unique() {
  d_cand="$(trim "${1:-}")"
  [ -n "$d_cand" ] || return 0
  case "${AXHUB_DISCOVERY_SEEN:-|}" in
    *"|$d_cand|"*) return 0 ;;
  esac
  AXHUB_DISCOVERY_SEEN="${AXHUB_DISCOVERY_SEEN:-|}|$d_cand|"
  if [ -z "${AXHUB_DISCOVERY_LIST:-}" ]; then
    AXHUB_DISCOVERY_LIST="$d_cand"
  else
    AXHUB_DISCOVERY_LIST="${AXHUB_DISCOVERY_LIST}
$d_cand"
  fi
}

discover_add_csv_candidates() {
  d_csv="$(trim "${1:-}")"
  [ -n "$d_csv" ] || return 0
  d_oldifs="$IFS"
  IFS=","
  for d_item in $d_csv; do
    discover_append_unique "$d_item"
  done
  IFS="$d_oldifs"
}

probe_pairing_discovery_endpoint() {
  p_host="$(trim "${1:-}")"
  p_pairing_port="$(uint_or_default "${2:-50052}" "50052")"
  p_timeout_sec="$(uint_or_default "${3:-2}" "2")"
  [ -n "$p_host" ] || return 1
  AXHUB_DISCOVERY_LAST_INTERNET_HOST=""
  AXHUB_DISCOVERY_LAST_HUB_INSTANCE_ID=""
  AXHUB_DISCOVERY_LAST_LAN_DISCOVERY_NAME=""
  AXHUB_DISCOVERY_LAST_PAIRING_PROFILE_EPOCH=""
  AXHUB_DISCOVERY_LAST_ROUTE_PACK_VERSION=""

  p_resp="$(curl -fsS --connect-timeout "$p_timeout_sec" --max-time "$p_timeout_sec" "http://${p_host}:${p_pairing_port}/pairing/discovery" 2>/dev/null || true)"
  if [ -n "$p_resp" ]; then
    p_ok="$(json_get_bool ok "$p_resp")"
    p_service="$(json_get_string service "$p_resp")"
    p_match="0"
    if [ "$p_ok" = "true" ]; then
      p_match="1"
    fi
    if [ "$p_match" != "1" ] && echo "$p_service" | grep -Eiq 'pair'; then
      p_match="1"
    fi
    if [ "$p_match" = "1" ]; then
      p_hint="$(trim "$(json_get_string hub_host_hint "$p_resp")")"
      [ -n "$p_hint" ] || p_hint="$p_host"
      p_pairing_port2="$(uint_or_default "$(json_get_number pairing_port "$p_resp")" "$p_pairing_port")"
      p_grpc_port2="$(uint_or_default "$(json_get_number grpc_port "$p_resp")" "50051")"
      p_tls_mode="$(trim "$(json_get_string tls_mode "$p_resp")")"
      p_tls_name="$(trim "$(json_get_string tls_server_name "$p_resp")")"
      AXHUB_DISCOVERY_LAST_INTERNET_HOST="$(trim "$(json_get_string internet_host_hint "$p_resp")")"
      AXHUB_DISCOVERY_LAST_HUB_INSTANCE_ID="$(trim "$(json_get_string hub_instance_id "$p_resp")")"
      AXHUB_DISCOVERY_LAST_LAN_DISCOVERY_NAME="$(trim "$(json_get_string lan_discovery_name "$p_resp")")"
      AXHUB_DISCOVERY_LAST_PAIRING_PROFILE_EPOCH="$(trim "$(json_get_number pairing_profile_epoch "$p_resp")")"
      AXHUB_DISCOVERY_LAST_ROUTE_PACK_VERSION="$(trim "$(json_get_string route_pack_version "$p_resp")")"
      echo "$p_hint|$p_pairing_port2|$p_grpc_port2|$p_tls_mode|$p_tls_name|$AXHUB_DISCOVERY_LAST_INTERNET_HOST|$AXHUB_DISCOVERY_LAST_HUB_INSTANCE_ID|$AXHUB_DISCOVERY_LAST_LAN_DISCOVERY_NAME|$AXHUB_DISCOVERY_LAST_PAIRING_PROFILE_EPOCH|$AXHUB_DISCOVERY_LAST_ROUTE_PACK_VERSION"
      return 0
    fi
  fi

  # Backward compatibility for old hubs without /pairing/discovery.
  p_health="$(curl -fsS --connect-timeout "$p_timeout_sec" --max-time "$p_timeout_sec" "http://${p_host}:${p_pairing_port}/health" 2>/dev/null || true)"
  if [ -n "$p_health" ]; then
    p_ok2="$(json_get_bool ok "$p_health")"
    p_service2="$(json_get_string service "$p_health")"
    if [ "$p_ok2" = "true" ] && [ "$p_service2" = "pairing" ]; then
      echo "$p_host|$p_pairing_port|50051|||||||"
      return 0
    fi
  fi

  return 1
}

discover_hub_endpoint() {
  d_pairing_port="$(uint_or_default "${1:-50052}" "50052")"
  d_timeout_sec="$(uint_or_default "${2:-2}" "2")"
  d_hints_csv="$(trim "${3:-}")"
  d_pairing_port_explicit="$(trim "${4:-0}")"

  AXHUB_DISCOVERY_SEEN="|"
  AXHUB_DISCOVERY_LIST=""
  AXHUB_DISCOVERY_LAST_INTERNET_HOST=""
  AXHUB_DISCOVERY_LAST_HUB_INSTANCE_ID=""
  AXHUB_DISCOVERY_LAST_LAN_DISCOVERY_NAME=""
  AXHUB_DISCOVERY_LAST_PAIRING_PROFILE_EPOCH=""
  AXHUB_DISCOVERY_LAST_ROUTE_PACK_VERSION=""

  # Priority:
  # 1) explicit hints
  # 2) HUB_DISCOVERY_HINTS env
  # 3) previously paired host(s)
  # 4) previously discovered Bonjour service name
  # 5) Bonjour browse (_axhub._tcp)
  # 6) axhub.local
  # 7) default gateway
  # 8) local machine
  discover_add_csv_candidates "$d_hints_csv"
  discover_add_csv_candidates "${HUB_DISCOVERY_HINTS:-}"

  if [ -f "$PAIRING_ENV" ]; then
    # shellcheck disable=SC1090
    . "$PAIRING_ENV"
    discover_append_unique "${AXHUB_HUB_HOST:-}"
    if [ -n "$(trim "${AXHUB_LAN_DISCOVERY_NAME:-}")" ]; then
      discover_append_unique "${AXHUB_LAN_DISCOVERY_NAME}.local"
    fi
    if [ "$d_pairing_port_explicit" != "1" ]; then
      prev_pairing_port="$(trim "${AXHUB_PAIRING_PORT:-}")"
      if [ -n "$prev_pairing_port" ]; then
        d_pairing_port="$(uint_or_default "$prev_pairing_port" "$d_pairing_port")"
      fi
    fi
  fi

  if [ -f "$HUB_ENV" ]; then
    # shellcheck disable=SC1090
    . "$HUB_ENV"
    discover_append_unique "${HUB_HOST:-}"
  fi

  discover_add_bonjour_candidates "$d_timeout_sec"
  discover_append_unique "axhub.local"
  discover_append_unique "$(default_gateway_host || true)"
  discover_append_unique "127.0.0.1"
  discover_append_unique "localhost"

  d_oldifs="$IFS"
  IFS='
'
  for d_host in $AXHUB_DISCOVERY_LIST; do
    d_row="$(probe_pairing_discovery_endpoint "$d_host" "$d_pairing_port" "$d_timeout_sec" || true)"
    if [ -n "$d_row" ]; then
      IFS="$d_oldifs"
      echo "$d_row"
      return 0
    fi
  done
  IFS="$d_oldifs"

  return 1
}

