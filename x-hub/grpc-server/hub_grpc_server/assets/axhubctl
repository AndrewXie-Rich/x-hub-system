#!/bin/sh
set -eu

AXHUBCTL_VERSION="0.3.0"
PROBE_LAST_ERROR=""

die() {
  echo "axhubctl: $*" >&2
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing command: $1"
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

run_self() {
  if [ -x "$0" ]; then
    "$0" "$@"
  else
    /bin/sh "$0" "$@"
  fi
}

trim() {
  # shellcheck disable=SC2001
  echo "$1" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//'
}

json_escape() {
  # Escape for a JSON string value (very small subset; good enough for IDs/names/tokens).
  # - backslash
  # - double quote
  echo "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g'
}

json_get_string() {
  key="$1"
  json="$2"
  # Extract first match of: "key":"value" (tolerate spaces)
  echo "$json" | tr -d '\n' | sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p" | head -n 1
}

json_get_number() {
  key="$1"
  json="$2"
  # Extract first integer match of: "key":123 (tolerate spaces)
  echo "$json" | tr -d '\n' | sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\\(-\\{0,1\\}[0-9][0-9]*\\).*/\\1/p" | head -n 1
}

json_get_bool() {
  key="$1"
  json="$2"
  # Extract first boolean match of: "key":true|false (tolerate spaces).
  # Use two passes for POSIX/BSD sed portability.
  v="$(echo "$json" | tr -d '\n' | sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\\(true\\).*/\\1/p" | head -n 1)"
  if [ -n "$v" ]; then
    echo "$v"
    return 0
  fi
  echo "$json" | tr -d '\n' | sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\\(false\\).*/\\1/p" | head -n 1
}

format_http_error_detail() {
  context="$1"
  body="$2"
  code="$(trim "$(json_get_string code "$body")")"
  msg="$(trim "$(json_get_string message "$body")")"

  # Pairing HTTP commonly nests the real reason in error.message while the top-level
  # code stays generic (for example forbidden/source_ip_not_allowed).
  effective="$code"
  if [ -n "$msg" ] && [ "$msg" != "$code" ]; then
    effective="$msg"
  fi

  case "$effective" in
    invite_token_required)
      echo "$context failed (invite_token_required). Hub requires an invite token for this pairing request. Re-open the current Hub invite link in X-Terminal or pass --invite-token."
      return 0
      ;;
    invite_token_invalid)
      echo "$context failed (invite_token_invalid). The invite token is expired, rotated, or does not match this Hub. Re-copy the current Hub invite link/token and retry."
      return 0
      ;;
    first_pair_requires_same_lan)
      echo "$context failed (first_pair_requires_same_lan). First pairing must be requested from the same Wi-Fi/LAN as the Hub."
      return 0
      ;;
    source_ip_not_allowed)
      echo "$context failed (source_ip_not_allowed). This source IP is not allowed by the Hub pairing policy. Use the Hub LAN/VPN IP, or update HUB_PAIRING_ALLOWED_CIDRS on the Hub."
      return 0
      ;;
  esac

  if [ -n "$code" ] && [ -n "$msg" ] && [ "$code" != "$msg" ]; then
    echo "$context failed ($code): $msg"
    return 0
  fi
  if [ -n "$code" ]; then
    echo "$context failed ($code)"
    return 0
  fi
  if [ -n "$msg" ]; then
    echo "$context failed: $msg"
    return 0
  fi
  return 1
}

is_uint() {
  v="$(trim "${1:-}")"
  case "$v" in
    ''|*[!0-9]*) return 1 ;;
    *) return 0 ;;
  esac
}

uint_or_default() {
  raw="$(trim "${1:-}")"
  def="$(trim "${2:-0}")"
  if is_uint "$raw"; then
    echo "$raw"
    return 0
  fi
  echo "$def"
}

json_quote_or_null() {
  v="$(trim "${1:-}")"
  if [ -n "$v" ]; then
    echo "\"$(json_escape "$v")\""
    return 0
  fi
  echo "null"
}

json_uint_or_null() {
  v="$(trim "${1:-}")"
  if is_uint "$v"; then
    echo "$v"
    return 0
  fi
  echo "null"
}

random_secret() {
  if command -v openssl >/dev/null 2>&1; then
    # URL-safe base64 without padding.
    openssl rand -base64 24 2>/dev/null | tr -d '\n' | tr '+/' '-_' | tr -d '='
    return
  fi
  # Fallback (not cryptographically perfect but ok for local pairing secret).
  dd if=/dev/urandom bs=1 count=24 2>/dev/null | base64 2>/dev/null | tr -d '\n' | tr '+/' '-_' | tr -d '='
}

usage() {
  cat <<'EOF'
axhubctl (MVP) - discover/pair/connect with AX Hub.

Usage:
  axhubctl discover [--pairing-port 50052] [--timeout-sec 2] [--hints "host1,host2"] [--quiet]
  axhubctl bootstrap [--hub auto|<host>] [--pairing-port 50052] [--grpc-port 50051] [--app-id ax_terminal] [--device-name NAME] [--requested-scopes "a,b,c"] [--invite-token TOKEN] [--require-client-kit|--skip-install-client]
  axhubctl knock [--hub auto|<host>] [--pairing-port 50052] [--grpc-port 50051] [--app-id ax_terminal] [--device-name NAME] [--requested-scopes "a,b,c"]
  axhubctl wait [--hub <host>] [--pairing-port 50052] [--grpc-port 50051] [--id <pairing_request_id>] [--secret <pairing_secret>] [--timeout-sec 900] [--interval-sec 2]
  axhubctl connect [--hub auto|<host>] [--grpc-port 50051] [--pairing-port 50052] [--auto-reconnect] [--max-backoff-sec 30] [--max-failures 0]
  axhubctl install-client [--hub <host>] [--pairing-port 50052] [--dir <path>]
  axhubctl new-chat [--project-id <id>] [--thread-key <key>]
  axhubctl list-models
  axhubctl skills search --query "<text>" [--source <id>] [--limit 20]
  axhubctl skills upload --file <skill.tgz> [--source <id>] [--manifest <skill.json>]
  axhubctl skills import --file <skill.tgz> --scope global|project [--project-id <id>] [--note "..."] [--source <id>] [--manifest <skill.json>]
  axhubctl skills pin --scope global|project --skill <skill_id> --sha <package_sha256> [--project-id <id>] [--note "..."]
  axhubctl skills resolved [--project-id <id>]
  axhubctl remote list-models                  # use ~/.axhub/tunnel.env override
  axhubctl chat-new --model <model_id> [--prompt "hi"] [other flags...]
  axhubctl chat --model <model_id> [--prompt "hi"] [other flags...]
  axhubctl remote chat --model <model_id> [--prompt "hi"] [other flags...]
  axhubctl tunnel --hub <host> [--grpc-port 50051] [--local-port 50051] [--local-host 127.0.0.1] [--quiet] [--install|--uninstall|--status]
  axhubctl env

Notes:
  - Pairing state is stored in ~/.axhub/pairing.env
  - After approval, it writes ~/.axhub/hub.env (exports HUB_HOST/HUB_PORT/HUB_CLIENT_TOKEN/HUB_DEVICE_ID) and ~/.axhub/connection.json
  - Chat state is stored in ~/.axhub/chat.env (exports HUB_PROJECT_ID/HUB_THREAD_KEY)
  - Tunnel state is stored in ~/.axhub/tunnel.env (overrides HUB_HOST/HUB_PORT to the local tunnel)
  - Tunnel service config is stored in ~/.axhub/tunnel_config.env (remote/local host+port)
  - (macOS) Tunnel service logs: ~/.axhub/tunnel_service.out.log / ~/.axhub/tunnel_service.err.log
  - install-client downloads a self-contained client kit from the Hub pairing port (no repo required; may include a bundled Node runtime)
EOF
}

STATE_DIR="${AXHUBCTL_STATE_DIR:-$HOME/.axhub}"
PAIRING_ENV="$STATE_DIR/pairing.env"
HUB_ENV="$STATE_DIR/hub.env"
CONNECTION_JSON="$STATE_DIR/connection.json"
CHAT_ENV="$STATE_DIR/chat.env"
TUNNEL_ENV="$STATE_DIR/tunnel.env"
TUNNEL_CONFIG_ENV="$STATE_DIR/tunnel_config.env"
TUNNEL_SERVICE_OUT_LOG="$STATE_DIR/tunnel_service.out.log"
TUNNEL_SERVICE_ERR_LOG="$STATE_DIR/tunnel_service.err.log"

cmd="${1:-help}"
shift || true

case "$cmd" in
  -h|--help|help)
    usage
    exit 0
    ;;
  version)
    echo "$AXHUBCTL_VERSION"
    exit 0
    ;;
esac

need_cmd curl

base64_encode_file_one_line() {
  fp="$(trim "${1:-}")"
  [ -n "$fp" ] || die "base64_encode_file_one_line: missing file path"
  [ -f "$fp" ] || die "base64_encode_file_one_line: file not found: $fp"
  # macOS base64 wraps by default; strip newlines.
  base64 <"$fp" 2>/dev/null | tr -d '\n'
}

base64_decode_to_file() {
  b64="$(trim "${1:-}")"
  out="$(trim "${2:-}")"
  [ -n "$b64" ] || die "base64_decode_to_file: missing base64 data"
  [ -n "$out" ] || die "base64_decode_to_file: missing output path"
  mkdir -p "$(dirname "$out")"
  umask 077
  # GNU coreutils: base64 -d ; macOS: base64 -D
  if echo "$b64" | tr -d '\n' | base64 -d >"$out" 2>/dev/null; then
    return 0
  fi
  if echo "$b64" | tr -d '\n' | base64 -D >"$out" 2>/dev/null; then
    return 0
  fi
  die "base64 decode failed (need base64 that supports -d or -D)"
}

ensure_tls_key_and_csr_b64() {
  # Best-effort: generate a client key + CSR so the Hub can issue an mTLS client cert.
  # If openssl is missing, return empty and proceed (Hub may be in insecure mode).
  if ! have_cmd openssl; then
    echo ""
    return 0
  fi

  tls_dir="$STATE_DIR/tls"
  key_path="$tls_dir/client.key.pem"
  csr_path="$tls_dir/client.csr.pem"

  mkdir -p "$tls_dir"
  umask 077

  if [ ! -f "$key_path" ]; then
    openssl genpkey -algorithm EC -pkeyopt ec_paramgen_curve:prime256v1 -pkeyopt ec_param_enc:named_curve -out "$key_path" >/dev/null 2>&1 || die "openssl genpkey failed"
    chmod 600 "$key_path" 2>/dev/null || true
  fi

  # Always refresh CSR (safe; uses existing key).
  openssl req -new -key "$key_path" -out "$csr_path" -subj "/CN=axhub-terminal" >/dev/null 2>&1 || die "openssl req (CSR) failed"
  chmod 600 "$csr_path" 2>/dev/null || true

  base64_encode_file_one_line "$csr_path"
}

sha256_verify() {
  expected="$(trim "${1:-}")"
  file="$(trim "${2:-}")"
  [ -n "$expected" ] || die "sha256_verify: missing expected hash"
  [ -n "$file" ] || die "sha256_verify: missing file path"

  if have_cmd shasum; then
    echo "$expected  $file" | shasum -a 256 -c - >/dev/null 2>&1 || return 1
    return 0
  fi
  if have_cmd sha256sum; then
    echo "$expected  $file" | sha256sum -c - >/dev/null 2>&1 || return 1
    return 0
  fi
  die "missing shasum or sha256sum (needed to verify downloads)"
}

mktemp_dir() {
  if have_cmd mktemp; then
    d="$(mktemp -d 2>/dev/null || true)"
    if [ -n "$d" ] && [ -d "$d" ]; then
      echo "$d"
      return 0
    fi
    d="$(mktemp -d -t axhubctl 2>/dev/null || true)"
    if [ -n "$d" ] && [ -d "$d" ]; then
      echo "$d"
      return 0
    fi
  fi
  d="/tmp/axhubctl.$$.$(date +%s)"
  mkdir -p "$d"
  echo "$d"
}

resolve_local_hub_grpc_server_dir() {
  # Dev fallback when Hub does not expose /install/axhub_client_kit.* assets.
  override="$(trim "${AXHUBCTL_LOCAL_HUB_GRPC_SERVER_DIR:-}")"
  if [ -n "$override" ] && [ -d "$override/src" ] && [ -f "$override/package.json" ]; then
    echo "$override"
    return 0
  fi

  self_abs="$0"
  case "$self_abs" in
    /*) ;;
    */*) self_abs="$(pwd)/$self_abs" ;;
    *)
      found="$(command -v "$self_abs" 2>/dev/null || true)"
      if [ -n "$found" ] && [ -f "$found" ]; then
        self_abs="$found"
      else
        self_abs="$(pwd)/$self_abs"
      fi
      ;;
  esac

  self_dir="$(dirname "$self_abs")"
  c1="$(cd "$self_dir/.." 2>/dev/null && pwd || true)"
  if [ -n "$c1" ] && [ -d "$c1/src" ] && [ -f "$c1/package.json" ]; then
    echo "$c1"
    return 0
  fi

  c2="$(cd "$self_dir/../.." 2>/dev/null && pwd || true)"
  if [ -n "$c2" ] && [ -d "$c2/hub_grpc_server/src" ] && [ -f "$c2/hub_grpc_server/package.json" ]; then
    echo "$c2/hub_grpc_server"
    return 0
  fi

  return 1
}

resolve_local_hub_proto_path() {
  override="$(trim "${AXHUBCTL_LOCAL_HUB_PROTO_PATH:-}")"
  if [ -n "$override" ] && [ -f "$override" ]; then
    echo "$override"
    return 0
  fi

  grpc_dir="$(trim "${1:-}")"
  [ -n "$grpc_dir" ] || return 1

  p1="$grpc_dir/../protocol/hub_protocol_v1.proto"
  [ -f "$p1" ] && { echo "$p1"; return 0; }

  p2="$grpc_dir/../../protocol/hub_protocol_v1.proto"
  [ -f "$p2" ] && { echo "$p2"; return 0; }

  p3="$grpc_dir/../../../protocol/hub_protocol_v1.proto"
  [ -f "$p3" ] && { echo "$p3"; return 0; }

  return 1
}

install_client_kit_from_local_repo() {
  # Best-effort fallback for dev builds that did not bundle axhub_client_kit.tgz.
  dst="$(trim "${1:-}")"
  [ -n "$dst" ] || return 1

  grpc_dir="$(resolve_local_hub_grpc_server_dir || true)"
  [ -n "$grpc_dir" ] || return 1
  [ -d "$grpc_dir/src" ] || return 1
  [ -f "$grpc_dir/package.json" ] || return 1

  proto_path="$(resolve_local_hub_proto_path "$grpc_dir" || true)"
  [ -n "$proto_path" ] || return 1

  tmpdir="$(mktemp_dir)"
  stage="$tmpdir/stage"
  mkdir -p "$stage/hub_grpc_server" "$stage/protocol"

  cp -R "$grpc_dir/src" "$stage/hub_grpc_server/" || return 1
  cp "$grpc_dir/package.json" "$stage/hub_grpc_server/" || return 1
  if [ -f "$grpc_dir/package-lock.json" ]; then
    cp "$grpc_dir/package-lock.json" "$stage/hub_grpc_server/" || true
  fi
  if [ -d "$grpc_dir/node_modules" ]; then
    cp -R "$grpc_dir/node_modules" "$stage/hub_grpc_server/" || return 1
  fi
  cp "$proto_path" "$stage/protocol/hub_protocol_v1.proto" || return 1

  rm -rf "$dst" 2>/dev/null || true
  mkdir -p "$(dirname "$dst")"
  mv -f "$stage" "$dst" || return 1
  clear_quarantine_flags "$dst"
  sign_binary_if_possible "$dst/bin/relflowhub_node"

  rm -rf "$tmpdir" 2>/dev/null || true
  return 0
}

sh_escape_single_quotes() {
  # Escape for a single-quoted shell string value.
  # Example: foo'bar -> foo'\''bar
  echo "$1" | sed "s/'/'\\\\''/g"
}

gen_id() {
  if have_cmd uuidgen; then
    uuidgen | tr '[:upper:]' '[:lower:]'
    return 0
  fi
  random_secret
}

maybe_source_tunnel_env() {
  # Optional: override HUB_HOST/HUB_PORT to the local tunnel endpoint (127.0.0.1:<port>).
  #
  # Enabled via:
  #   AXHUBCTL_USE_TUNNEL=1 axhubctl list-models
  #   AXHUBCTL_USE_TUNNEL=1 axhubctl chat ...
  use="$(trim "${AXHUBCTL_USE_TUNNEL:-}")"
  if [ "$use" = "1" ] || [ "$use" = "true" ] || [ "$use" = "yes" ]; then
    [ -f "$TUNNEL_ENV" ] || die "tunnel override requested but not found: $TUNNEL_ENV (run: $0 tunnel ...)"
    # shellcheck disable=SC1090
    . "$TUNNEL_ENV"
  fi
}

os_name() {
  uname -s 2>/dev/null || echo ""
}

is_darwin() {
  [ "$(os_name)" = "Darwin" ]
}

clear_quarantine_flags() {
  target="$(trim "${1:-}")"
  [ -n "$target" ] || return 0
  if have_cmd xattr; then
    xattr -dr com.apple.quarantine "$target" >/dev/null 2>&1 || true
  fi
}

sign_binary_if_possible() {
  bin_path="$(trim "${1:-}")"
  [ -n "$bin_path" ] || return 0
  [ -f "$bin_path" ] || return 0
  chmod +x "$bin_path" 2>/dev/null || true
  if is_darwin && have_cmd codesign; then
    # Best-effort ad-hoc signing so macOS won't kill helper binaries in some environments.
    codesign --force --sign - "$bin_path" >/dev/null 2>&1 || true
  fi
}

run_node_script() {
  n_bin="$(trim "${1:-}")"
  n_script="$(trim "${2:-}")"
  shift 2 || true
  [ -n "$n_bin" ] || die "missing node binary"
  [ -n "$n_script" ] || die "missing node script"

  n_rc=0
  "$n_bin" "$n_script" "$@" || n_rc=$?
  [ "$n_rc" -eq 0 ] && return 0

  case "$n_rc" in
    126) die "node runtime is not executable: $n_bin" ;;
    127) die "node runtime not found: $n_bin" ;;
    130|134|137|139|143)
      die "node runtime killed (exit=$n_rc, node=$n_bin)"
      ;;
  esac
  return "$n_rc"
}

xml_escape() {
  # Minimal XML escaping for plist string nodes.
  echo "$1" | sed -e 's/&/&amp;/g' -e 's/</&lt;/g' -e 's/>/&gt;/g'
}

tunnel_service_label() {
  echo "com.rel.flowhub.axhubctl.tunnel"
}

tunnel_service_plist_path() {
  echo "$HOME/Library/LaunchAgents/$(tunnel_service_label).plist"
}

launchctl_domain() {
  # Per-user GUI domain.
  uid="$(id -u 2>/dev/null || echo "")"
  [ -n "$uid" ] || uid="$(whoami 2>/dev/null || echo 0)"
  echo "gui/$uid"
}

ensure_axhubctl_installed_path() {
  # Launchd needs a stable absolute path; /tmp is not.
  self_abs="$0"
  case "$self_abs" in
    /*) ;;
    */*) self_abs="$(pwd)/$self_abs" ;;
    *)
      found="$(command -v "$self_abs" 2>/dev/null || true)"
      if [ -n "$found" ] && [ -f "$found" ]; then
        self_abs="$found"
      else
        self_abs="$(pwd)/$self_abs"
      fi
      ;;
  esac

  dst="${AXHUBCTL_INSTALL_PATH:-$HOME/.local/bin/axhubctl}"
  dst_dir="$(dirname "$dst")"
  mkdir -p "$dst_dir"
  cp -f "$self_abs" "$dst" || die "failed to install axhubctl to $dst (copy from $self_abs)"
  chmod +x "$dst" 2>/dev/null || true
  echo "$dst"
}

tunnel_service_status() {
  label="$(tunnel_service_label)"
  plist="$(tunnel_service_plist_path)"
  if ! is_darwin; then
    echo "Tunnel service install/status is only supported on macOS (launchd)."
    return 2
  fi
  if [ ! -f "$plist" ]; then
    echo "Tunnel service: not installed ($plist missing)"
    return 1
  fi

  dom="$(launchctl_domain)"
  if launchctl print "$dom/$label" >/dev/null 2>&1; then
    echo "Tunnel service: installed + loaded ($label)"
    return 0
  fi
  echo "Tunnel service: installed but not loaded ($label)"
  return 1
}

save_tunnel_env_override() {
  local_host="$(trim "${1:-127.0.0.1}")"
  local_port="$(trim "${2:-50051}")"
  [ -n "$local_host" ] || local_host="127.0.0.1"
  [ -n "$local_port" ] || local_port="50051"

  mkdir -p "$STATE_DIR"
  umask 077
  lhost_esc="$(sh_escape_single_quotes "$local_host")"
  lport_esc="$(sh_escape_single_quotes "$local_port")"
  cat >"$TUNNEL_ENV" <<EOF
export HUB_HOST='$lhost_esc'
export HUB_PORT='$lport_esc'
EOF
  chmod 600 "$TUNNEL_ENV" 2>/dev/null || true
}

save_tunnel_config_env() {
  local_host="$(trim "${1:-127.0.0.1}")"
  local_port="$(trim "${2:-50051}")"
  remote_host="$(trim "${3:-}")"
  remote_port="$(trim "${4:-50051}")"
  node_bin="$(trim "${5:-}")"
  kit_dir="$(trim "${6:-}")"
  [ -n "$remote_host" ] || die "save_tunnel_config_env: missing remote_host"
  [ -n "$remote_port" ] || remote_port="50051"

  mkdir -p "$STATE_DIR"
  umask 077
  lhost_esc="$(sh_escape_single_quotes "$local_host")"
  lport_esc="$(sh_escape_single_quotes "$local_port")"
  rhost_esc="$(sh_escape_single_quotes "$remote_host")"
  rport_esc="$(sh_escape_single_quotes "$remote_port")"
  cat >"$TUNNEL_CONFIG_ENV" <<EOF
export AXHUB_TUNNEL_LOCAL_HOST='$lhost_esc'
export AXHUB_TUNNEL_LOCAL_PORT='$lport_esc'
export AXHUB_TUNNEL_REMOTE_HOST='$rhost_esc'
export AXHUB_TUNNEL_REMOTE_PORT='$rport_esc'
EOF
  if [ -n "$node_bin" ]; then
    node_esc="$(sh_escape_single_quotes "$node_bin")"
    echo "export AXHUBCTL_NODE_BIN='$node_esc'" >>"$TUNNEL_CONFIG_ENV"
  fi
  if [ -n "$kit_dir" ]; then
    kit_esc="$(sh_escape_single_quotes "$kit_dir")"
    echo "export AXHUBCTL_CLIENT_KIT_DIR='$kit_esc'" >>"$TUNNEL_CONFIG_ENV"
  fi
  chmod 600 "$TUNNEL_CONFIG_ENV" 2>/dev/null || true
}

load_tunnel_config_env_if_present() {
  if [ -f "$TUNNEL_CONFIG_ENV" ]; then
    # shellcheck disable=SC1090
    . "$TUNNEL_CONFIG_ENV"
  fi
}

write_tunnel_service_plist() {
  axhubctl_path="$(trim "${1:-}")"
  [ -n "$axhubctl_path" ] || die "write_tunnel_service_plist: missing axhubctl_path"

  if ! is_darwin; then
    die "tunnel service install is only supported on macOS (launchd)"
  fi

  label="$(tunnel_service_label)"
  plist="$(tunnel_service_plist_path)"
  mkdir -p "$(dirname "$plist")"
  mkdir -p "$STATE_DIR"

  out_log="$TUNNEL_SERVICE_OUT_LOG"
  err_log="$TUNNEL_SERVICE_ERR_LOG"

  # launchd expects a plist with absolute paths.
  axhubctl_esc="$(xml_escape "$axhubctl_path")"
  out_log_esc="$(xml_escape "$out_log")"
  err_log_esc="$(xml_escape "$err_log")"

  cat >"$plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>${label}</string>
    <key>ProgramArguments</key>
    <array>
      <string>${axhubctl_esc}</string>
      <string>tunnel</string>
      <string>--from-config</string>
      <string>--quiet</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>10</integer>
    <key>StandardOutPath</key>
    <string>${out_log_esc}</string>
    <key>StandardErrorPath</key>
    <string>${err_log_esc}</string>
  </dict>
</plist>
EOF
  chmod 644 "$plist" 2>/dev/null || true
  echo "$plist"
}

tunnel_service_install() {
  if ! is_darwin; then
    die "tunnel service install is only supported on macOS (launchd)"
  fi
  need_cmd launchctl

  plist="$(tunnel_service_plist_path)"
  dom="$(launchctl_domain)"
  label="$(tunnel_service_label)"

  # Reload (best-effort) so edits to the plist take effect.
  launchctl bootout "$dom" "$plist" >/dev/null 2>&1 || true
  launchctl bootstrap "$dom" "$plist" >/dev/null 2>&1 || die "launchctl bootstrap failed (plist=$plist)"
  launchctl kickstart -k "$dom/$label" >/dev/null 2>&1 || true
}

tunnel_service_uninstall() {
  if ! is_darwin; then
    die "tunnel service uninstall is only supported on macOS (launchd)"
  fi
  need_cmd launchctl

  plist="$(tunnel_service_plist_path)"
  dom="$(launchctl_domain)"
  launchctl bootout "$dom" "$plist" >/dev/null 2>&1 || true
  rm -f "$plist" 2>/dev/null || true
}

