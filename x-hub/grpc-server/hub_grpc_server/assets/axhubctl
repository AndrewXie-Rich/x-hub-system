  chat)
    [ -f "$HUB_ENV" ] || die "no env file yet; run: $0 knock && $0 wait"
    # shellcheck disable=SC1090
    . "$HUB_ENV"
    maybe_source_tunnel_env
    if [ -f "$CHAT_ENV" ]; then
      # shellcheck disable=SC1090
      . "$CHAT_ENV"
    fi

    KIT_DIR="${AXHUBCTL_CLIENT_KIT_DIR:-$STATE_DIR/client_kit}"
    [ -f "$KIT_DIR/hub_grpc_server/src/chat_client.js" ] || die "client kit not installed; run: $0 install-client"
    NODE_BIN="$(resolve_node_bin "$KIT_DIR" || true)"
    [ -n "$NODE_BIN" ] || die "missing node (install Node.js, or use a Hub build that bundles node in the client kit)"
    run_node_script "$NODE_BIN" "$KIT_DIR/hub_grpc_server/src/chat_client.js" "$@"
    ;;

  env)
    if [ ! -f "$HUB_ENV" ]; then
      die "no env file yet; run: $0 knock && $0 wait"
    fi
    cat "$HUB_ENV"
    ;;

  tunnel)
    # Local TCP forwarder for "remote" Mode 3. Keep gRPC clients pointed at 127.0.0.1:<local_port>.
    #
    # Security note:
    # - This tunnel is byte-forwarding only. It does NOT terminate TLS.
    # - gRPC mTLS + token auth remains end-to-end between client and Hub.
    remote_host=""
    remote_port="50051"
    local_host="127.0.0.1"
    local_port="50051"
    quiet="0"
    action=""
    from_config="0"
    remote_set="0"

    # Best-effort: use paired Hub env defaults if present.
    if [ -f "$HUB_ENV" ]; then
      # shellcheck disable=SC1090
      . "$HUB_ENV"
      remote_host="${HUB_HOST:-$remote_host}"
      remote_port="${HUB_PORT:-$remote_port}"
    fi

    while [ "$#" -gt 0 ]; do
      case "$1" in
        --hub|--remote-host)
          remote_host="${2:-}"
          remote_set="1"
          shift 2
          ;;
        --grpc-port|--remote-port) remote_port="${2:-}"; shift 2 ;;
        --remote)
          remote="$(trim "${2:-}")"
          shift 2
          if [ -n "$remote" ]; then
            remote_set="1"
            if echo "$remote" | grep -q ":"; then
              remote_host="${remote%:*}"
              remote_port="${remote##*:}"
            else
              remote_host="$remote"
            fi
          fi
          ;;
        --local-host) local_host="${2:-}"; shift 2 ;;
        --local-port) local_port="${2:-}"; shift 2 ;;
        -q|--quiet) quiet="1"; shift 1 ;;
        --from-config) from_config="1"; shift 1 ;;
        --install)
          [ -z "$action" ] || die "tunnel: only one of --install/--uninstall/--status is allowed"
          action="install"
          shift 1
          ;;
        --uninstall)
          [ -z "$action" ] || die "tunnel: only one of --install/--uninstall/--status is allowed"
          action="uninstall"
          shift 1
          ;;
        --status)
          [ -z "$action" ] || die "tunnel: only one of --install/--uninstall/--status is allowed"
          action="status"
          shift 1
          ;;
        -h|--help)
          echo "Usage:"
          echo "  axhubctl tunnel --hub <host> [--grpc-port 50051] [--local-port 50051] [--local-host 127.0.0.1] [--quiet]"
          echo "  axhubctl tunnel --remote <host:port> [--local-port 50051]"
          echo "  axhubctl tunnel --hub <host> [--grpc-port 50051] [--local-port 50051] --install     # (macOS) background service"
          echo "  axhubctl tunnel --uninstall                                                   # (macOS) remove service"
          echo "  axhubctl tunnel --status                                                      # (macOS) service status"
          exit 0
          ;;
        *) die "unknown arg: $1" ;;
      esac
    done

    if [ "$action" = "status" ]; then
      tunnel_service_status || true
      if [ -f "$TUNNEL_CONFIG_ENV" ]; then
        echo "Tunnel config: $TUNNEL_CONFIG_ENV"
        # Safe to print (no tokens); only host/port.
        cat "$TUNNEL_CONFIG_ENV" 2>/dev/null || true
      else
        echo "Tunnel config: not set (expected at $TUNNEL_CONFIG_ENV)"
      fi
      if [ -f "$TUNNEL_ENV" ]; then
        echo "Tunnel override: $TUNNEL_ENV"
        cat "$TUNNEL_ENV" 2>/dev/null || true
      else
        echo "Tunnel override: not set (expected at $TUNNEL_ENV)"
      fi
      exit 0
    fi

    if [ "$action" = "uninstall" ]; then
      if is_darwin; then
        tunnel_service_uninstall
      else
        echo "Tunnel service uninstall is only supported on macOS (launchd)."
      fi
      rm -f "$TUNNEL_CONFIG_ENV" "$TUNNEL_ENV" 2>/dev/null || true
      echo "Tunnel service removed (best-effort)."
      exit 0
    fi

    if [ "$from_config" = "1" ]; then
      load_tunnel_config_env_if_present
      remote_host="${AXHUB_TUNNEL_REMOTE_HOST:-$remote_host}"
      remote_port="${AXHUB_TUNNEL_REMOTE_PORT:-$remote_port}"
      local_host="${AXHUB_TUNNEL_LOCAL_HOST:-$local_host}"
      local_port="${AXHUB_TUNNEL_LOCAL_PORT:-$local_port}"
    fi

    remote_host="$(trim "$remote_host")"
    remote_port="$(trim "${remote_port:-50051}")"
    local_host="$(trim "${local_host:-127.0.0.1}")"
    local_port="$(trim "${local_port:-50051}")"
    if [ "$action" = "install" ] && [ "$remote_set" != "1" ]; then
      # Avoid accidentally installing a service that points at the LAN HUB_HOST from hub.env.
      if [ -f "$TUNNEL_CONFIG_ENV" ]; then
        load_tunnel_config_env_if_present
        remote_host="${AXHUB_TUNNEL_REMOTE_HOST:-$remote_host}"
        remote_port="${AXHUB_TUNNEL_REMOTE_PORT:-$remote_port}"
        local_host="${AXHUB_TUNNEL_LOCAL_HOST:-$local_host}"
        local_port="${AXHUB_TUNNEL_LOCAL_PORT:-$local_port}"
      else
        die "tunnel --install requires --hub (tailnet/VPN host), or an existing $TUNNEL_CONFIG_ENV"
      fi
    fi

    [ -n "$remote_host" ] || die "--hub is required (or set HUB_HOST in $HUB_ENV, or use --from-config after --install)"

    if [ "$action" = "install" ]; then
      if ! is_darwin; then
        die "tunnel --install is only supported on macOS (launchd)"
      fi

      KIT_DIR="${AXHUBCTL_CLIENT_KIT_DIR:-$STATE_DIR/client_kit}"
      case "$KIT_DIR" in
        /*) ;;
        *) KIT_DIR="$(pwd)/$KIT_DIR" ;;
      esac
      [ -f "$KIT_DIR/hub_grpc_server/src/tcp_tunnel.js" ] || die "client kit not installed; run: $0 install-client"
      NODE_BIN="$(resolve_node_bin "$KIT_DIR" || true)"
      [ -n "$NODE_BIN" ] || die "missing node (install Node.js, or use a Hub build that bundles node in the client kit)"

      save_tunnel_config_env "$local_host" "$local_port" "$remote_host" "$remote_port" "$NODE_BIN" "$KIT_DIR"
      save_tunnel_env_override "$local_host" "$local_port"

      axhubctl_path="$(ensure_axhubctl_installed_path)"
      plist_written="$(write_tunnel_service_plist "$axhubctl_path")"
      tunnel_service_install

      echo "Tunnel service installed."
      echo "  axhubctl : $axhubctl_path"
      echo "  plist    : $plist_written"
      echo "  config   : $TUNNEL_CONFIG_ENV"
      echo "  override : $TUNNEL_ENV"
      echo ""
      echo "Verify:"
      echo "  $axhubctl_path tunnel --status"
      echo "Use (via tunnel):"
      echo "  $axhubctl_path remote list-models"
      exit 0
    fi

    KIT_DIR="${AXHUBCTL_CLIENT_KIT_DIR:-$STATE_DIR/client_kit}"
    [ -f "$KIT_DIR/hub_grpc_server/src/tcp_tunnel.js" ] || die "client kit missing tcp_tunnel.js; re-run: $0 install-client (and rebuild Hub app to refresh the client kit)"
    NODE_BIN="$(resolve_node_bin "$KIT_DIR" || true)"
    [ -n "$NODE_BIN" ] || die "missing node (install Node.js, or use a Hub build that bundles node in the client kit)"

    save_tunnel_env_override "$local_host" "$local_port"

    if [ "$quiet" != "1" ]; then
      echo "Tunnel starting…"
      echo "  local : ${local_host}:${local_port}"
      echo "  remote: ${remote_host}:${remote_port}"
      echo "Saved tunnel override: $TUNNEL_ENV"
      echo ""
      echo "Use it:"
      echo "  $0 remote list-models"
      echo ""
    fi

    export AXHUB_TUNNEL_LOCAL_HOST="$local_host"
    export AXHUB_TUNNEL_LOCAL_PORT="$local_port"
    export AXHUB_TUNNEL_REMOTE_HOST="$remote_host"
    export AXHUB_TUNNEL_REMOTE_PORT="$remote_port"

    if [ "$quiet" = "1" ]; then
      exec "$NODE_BIN" "$KIT_DIR/hub_grpc_server/src/tcp_tunnel.js" --quiet
    fi
    exec "$NODE_BIN" "$KIT_DIR/hub_grpc_server/src/tcp_tunnel.js"
    ;;

  *)
    usage
    die "unknown command: $cmd"
    ;;
esac
